#!/usr/bin/env bash
set -euo pipefail

target_path=""
fallback_path=""
label="Lumina report"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --target)
            target_path="${2:-}"
            shift 2
            ;;
        --fallback)
            fallback_path="${2:-}"
            shift 2
            ;;
        --label)
            label="${2:-}"
            shift 2
            ;;
        *)
            printf 'Unknown argument: %s\n' "$1" >&2
            exit 1
            ;;
    esac
done

open_path() {
    local candidate="$1"
    [[ -n "${candidate}" && -e "${candidate}" ]] || return 1

    if command -v dolphin >/dev/null 2>&1; then
        if [[ -f "${candidate}" ]]; then
            dolphin --select "${candidate}" >/dev/null 2>&1 &
        else
            dolphin "${candidate}" >/dev/null 2>&1 &
        fi
        sleep 1
        return 0
    fi

    if command -v kioclient5 >/dev/null 2>&1; then
        kioclient5 exec "${candidate}" >/dev/null 2>&1 &
        return 0
    fi

    if command -v gio >/dev/null 2>&1; then
        gio open "${candidate}" >/dev/null 2>&1 &
        return 0
    fi

    if command -v xdg-open >/dev/null 2>&1; then
        xdg-open "${candidate}" >/dev/null 2>&1 &
        return 0
    fi

    return 1
}

if open_path "${target_path}"; then
    exit 0
fi

if [[ "${fallback_path}" != "${target_path}" ]] && open_path "${fallback_path}"; then
    exit 0
fi

if command -v kdialog >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
    kdialog --title "Lumina-OS" --error "${label} could not be opened automatically." 2>/dev/null || true
fi

printf '%s could not be opened automatically.\n' "${label}" >&2
exit 1
