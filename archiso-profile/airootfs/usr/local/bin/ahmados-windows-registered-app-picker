#!/usr/bin/env bash
set -euo pipefail

selected_profile_id=""
selected_app_id=""
open_report=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile-id)
            selected_profile_id="${2:-}"
            shift 2
            ;;
        --app-id)
            selected_app_id="${2:-}"
            shift 2
            ;;
        --no-open)
            open_report=0
            shift
            ;;
        *)
            printf 'Unknown argument: %s\n' "$1" >&2
            exit 1
            ;;
    esac
done

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/ahmados"
documents_root="${XDG_DOCUMENTS_DIR:-$HOME/Documents}"
mkdir -p "${state_root}"

profiles_path="/usr/share/lumina/windows-apps/profiles.tsv"
picker_report="${state_root}/windows-registered-app-picker.md"
launch_report="${state_root}/windows-registered-app-launch.md"
surfaces_report="${state_root}/windows-app-surfaces.md"

if [[ -z "${selected_profile_id}" ]]; then
    selected_profile_id="adobe-creator"
fi

selected_row="$(awk -F'|' -v target="${selected_profile_id}" 'NF >= 8 && $1 == target {print; exit}' "${profiles_path}" || true)"
if [[ -z "${selected_row}" ]]; then
    printf 'Unknown Windows profile id: %s\n' "${selected_profile_id}" >&2
    exit 1
fi

IFS='|' read -r profile_id profile_name focus app_ids basic_route vm_route studio_route notes <<< "${selected_row}"

/usr/local/bin/ahmados-windows-app-surfaces --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

workspace_root="${documents_root}/Lumina Windows Workflows/${profile_id}"
surfaces_index_path="${workspace_root}/app-registry/launcher-surfaces.tsv"

choose_app_with_kdialog() {
    local entries=()

    while IFS='|' read -r app_id app_name surface_state launcher_script launcher_desktop manifest_path; do
        [[ -z "${app_id}" || "${app_id}" == \#* ]] && continue
        entries+=("${app_id}" "${app_name} - ${surface_state}")
    done < "${surfaces_index_path}"

    if [[ ${#entries[@]} -eq 0 ]]; then
        return 1
    fi

    kdialog --title "Lumina Windows Apps" \
        --menu "Choose the registered Windows app you want Lumina to launch." \
        "${entries[@]}" 2>/dev/null || return 1
}

if [[ -z "${selected_app_id}" && -f "${surfaces_index_path}" && -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]] && command -v kdialog >/dev/null 2>&1; then
    selected_app_id="$(choose_app_with_kdialog || true)"
fi

if [[ -z "${selected_app_id}" && -f "${surfaces_index_path}" ]]; then
    selected_app_id="$(awk -F'|' 'NF >= 3 && $1 !~ /^#/ && $3 == "ready" {print $1; exit}' "${surfaces_index_path}" || true)"
fi

if [[ -z "${selected_app_id}" ]]; then
    printf 'No registered app surface is ready yet for profile: %s\n' "${profile_id}" >&2
    exit 1
fi

/usr/local/bin/ahmados-windows-registered-app-launch --profile-id "${profile_id}" --app-id "${selected_app_id}" --no-open >/dev/null 2>&1 || true

selected_surface_row="$(awk -F'|' -v target="${selected_app_id}" 'NF >= 6 && $1 == target {print; exit}' "${surfaces_index_path}" || true)"
IFS='|' read -r app_id app_name surface_state launcher_script launcher_desktop manifest_path <<< "${selected_surface_row}"

launch_outcome="$(awk -F': ' '/^- Launch Outcome:/ {print $2; exit}' "${launch_report}" 2>/dev/null || true)"
guest_launch_status="$(awk -F': ' '/^- Guest Launch Status:/ {print $2; exit}' "${launch_report}" 2>/dev/null || true)"
launch_note="$(awk 'found && /^- / {sub(/^- /,""); print; exit} /^## Launch Note/ {found=1}' "${launch_report}" 2>/dev/null || true)"

{
    printf '# Lumina Windows Registered App Picker\n\n'
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Profile: %s\n' "${profile_name}"
    printf -- '- Profile Id: %s\n' "${profile_id}"
    printf -- '- Selected App Id: %s\n' "${app_id}"
    printf -- '- Selected App Name: %s\n' "${app_name}"
    printf -- '- Surface State: %s\n' "${surface_state}"
    printf -- '- Launch Outcome: %s\n' "${launch_outcome:-unknown}"
    printf -- '- Guest Launch Status: %s\n' "${guest_launch_status:-unknown}"
    printf '\n## Launch Note\n'
    printf -- '- %s\n' "${launch_note:-No launch note was captured yet.}"
    printf '\n## Related Paths\n'
    printf -- '- Launcher Script: %s\n' "${launcher_script}"
    printf -- '- Launcher Desktop: %s\n' "${launcher_desktop}"
    printf -- '- App Manifest: %s\n' "${manifest_path}"
    printf '\n## Related Reports\n'
    printf -- '- App Surfaces Report: %s\n' "${surfaces_report}"
    printf -- '- Registered App Launch Report: %s\n' "${launch_report}"
} > "${picker_report}"

printf '%s\n' '========================================'
printf '%s\n' '   Lumina Registered App Picker'
printf '%s\n' '========================================'
printf '\n'
printf 'Profile: %s\n' "${profile_name}"
printf 'Selected app: %s\n' "${app_name}"
printf 'Report: %s\n' "${picker_report}"
printf '\n'

if [[ ${open_report} -eq 1 ]] && command -v xdg-open >/dev/null 2>&1; then
    xdg-open "${picker_report}" >/dev/null 2>&1 || true
fi
