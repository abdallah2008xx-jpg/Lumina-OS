#!/usr/bin/env bash
set -euo pipefail

selected_profile_id=""
open_report=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile-id)
            selected_profile_id="${2:-}"
            shift 2
            ;;
        --no-open)
            open_report=0
            shift
            ;;
        *)
            printf 'Unknown argument: %s\n' "$1" >&2
            exit 1
            ;;
    esac
done

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/ahmados"
documents_root="${XDG_DOCUMENTS_DIR:-$HOME/Documents}"
data_root="${XDG_DATA_HOME:-$HOME/.local/share}"
mkdir -p "${state_root}"

profiles_path="/usr/share/lumina/windows-apps/profiles.tsv"
daily_menu_export_report="${state_root}/windows-daily-menu-export.md"
daily_surface_report="${state_root}/windows-daily-surface.md"
app_library_report="${state_root}/windows-app-library.md"
hub_report="${state_root}/windows-workflow-hub.md"
state_report="${state_root}/windows-workflow-state.md"
compat_report="${state_root}/windows-compat-report.md"

if [[ -z "${selected_profile_id}" ]]; then
    selected_profile_id="adobe-creator"
fi

selected_row="$(awk -F'|' -v target="${selected_profile_id}" 'NF >= 8 && $1 == target {print; exit}' "${profiles_path}" || true)"
if [[ -z "${selected_row}" ]]; then
    printf 'Unknown Windows profile id: %s\n' "${selected_profile_id}" >&2
    exit 1
fi

IFS='|' read -r profile_id profile_name focus app_ids basic_route vm_route studio_route notes <<< "${selected_row}"

/usr/local/bin/ahmados-windows-app-library --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true
/usr/local/bin/ahmados-windows-daily-surface --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

workspace_root="${documents_root}/Lumina Windows Workflows/${profile_id}"
workflow_state_root="${workspace_root}/state"
export_dir="${data_root}/applications/lumina-windows-daily/${profile_id}"
daily_menu_export_marker="${workflow_state_root}/daily-menu-export-ready.marker"

mkdir -p "${export_dir}" "${workflow_state_root}"

find "${export_dir}" -maxdepth 1 -type f -name "lumina-windows-daily-${profile_id}-*.desktop" -delete 2>/dev/null || true

resource_class="$(awk -F': ' '/^- Resource Class:/ {print $2; exit}' "${compat_report}" 2>/dev/null || true)"
surface_mode="$(awk -F': ' '/^- Surface Mode:/ {print $2; exit}' "${daily_surface_report}" 2>/dev/null || true)"
recommended_collection="$(awk -F': ' '/^- Recommended Collection:/ {print $2; exit}' "${app_library_report}" 2>/dev/null || true)"
[[ -n "${resource_class}" ]] || resource_class="balanced"
[[ -n "${surface_mode}" ]] || surface_mode="guided-setup"
[[ -n "${recommended_collection}" ]] || recommended_collection="none"

comment_suffix="Resource class ${resource_class}; surface mode ${surface_mode}."

cat > "${export_dir}/lumina-windows-daily-${profile_id}-surface.desktop" <<EOF
[Desktop Entry]
Type=Application
Version=1.0
Name=${profile_name} Windows Apps (Lumina)
Comment=Open the daily Windows Apps surface for ${profile_name}. ${comment_suffix}
Exec=/usr/local/bin/lumina-windows-daily-surface --profile-id ${profile_id}
Icon=applications-system
Terminal=false
Categories=Utility;System;
StartupNotify=true
Keywords=Windows;Lumina;Daily;${profile_name};
EOF

cat > "${export_dir}/lumina-windows-daily-${profile_id}-best.desktop" <<EOF
[Desktop Entry]
Type=Application
Version=1.0
Name=Best ${profile_name} Windows Apps (Lumina)
Comment=Launch the best published Windows app collection for ${profile_name}. ${comment_suffix}
Exec=/usr/local/bin/lumina-windows-app-library --profile-id ${profile_id} --launch-best
Icon=applications-other
Terminal=false
Categories=Utility;System;
StartupNotify=true
Keywords=Windows;Lumina;Best;${profile_name};
EOF

cat > "${export_dir}/lumina-windows-daily-${profile_id}-choose.desktop" <<EOF
[Desktop Entry]
Type=Application
Version=1.0
Name=Choose ${profile_name} Windows Collection (Lumina)
Comment=Choose the Windows app collection Lumina should open for ${profile_name}. ${comment_suffix}
Exec=/usr/local/bin/lumina-windows-app-library --profile-id ${profile_id} --choose-collection
Icon=view-list-icons
Terminal=false
Categories=Utility;System;
StartupNotify=true
Keywords=Windows;Lumina;Choose;Collection;${profile_name};
EOF

if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database "${export_dir}" >/dev/null 2>&1 || true
fi

touch "${daily_menu_export_marker}"
/usr/local/bin/ahmados-windows-workflow-state --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

{
    printf '# Lumina Windows Daily Menu Export\n\n'
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Profile: %s\n' "${profile_name}"
    printf -- '- Profile Id: %s\n' "${profile_id}"
    printf -- '- Resource Class: %s\n' "${resource_class}"
    printf -- '- Surface Mode: %s\n' "${surface_mode}"
    printf -- '- Recommended Collection: %s\n' "${recommended_collection}"
    printf -- '- Export Directory: %s\n' "${export_dir}"
    printf -- '- Daily Menu Export Marker: %s\n' "${daily_menu_export_marker}"
    printf '\n## Exported Shortcuts\n'
    printf -- '- Daily Surface: %s\n' "${export_dir}/lumina-windows-daily-${profile_id}-surface.desktop"
    printf -- '- Best Collection Launch: %s\n' "${export_dir}/lumina-windows-daily-${profile_id}-best.desktop"
    printf -- '- Collection Chooser: %s\n' "${export_dir}/lumina-windows-daily-${profile_id}-choose.desktop"
    printf '\n## Related Reports\n'
    printf -- '- Daily Surface Report: %s\n' "${daily_surface_report}"
    printf -- '- App Library Report: %s\n' "${app_library_report}"
    printf -- '- Workflow Hub Report: %s\n' "${hub_report}"
    printf -- '- Workflow State Report: %s\n' "${state_report}"
} > "${daily_menu_export_report}"

printf '%s\n' '========================================'
printf '%s\n' '   Lumina Windows Daily Menu Export'
printf '%s\n' '========================================'
printf '\n'
printf 'Profile: %s\n' "${profile_name}"
printf 'Surface mode: %s\n' "${surface_mode}"
printf 'Export dir: %s\n' "${export_dir}"
printf 'Report: %s\n' "${daily_menu_export_report}"
printf '\n'

if [[ ${open_report} -eq 1 ]] && command -v xdg-open >/dev/null 2>&1; then
    xdg-open "${daily_menu_export_report}" >/dev/null 2>&1 || true
fi
