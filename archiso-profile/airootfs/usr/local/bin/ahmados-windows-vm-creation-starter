#!/usr/bin/env bash
set -euo pipefail

selected_profile_id=""
open_report=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile-id)
            selected_profile_id="${2:-}"
            shift 2
            ;;
        --no-open)
            open_report=0
            shift
            ;;
        *)
            printf 'Unknown argument: %s\n' "$1" >&2
            exit 1
            ;;
    esac
done

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/ahmados"
documents_root="${XDG_DOCUMENTS_DIR:-$HOME/Documents}"
mkdir -p "${state_root}"

profiles_path="/usr/share/lumina/windows-apps/profiles.tsv"
starter_report="${state_root}/windows-vm-creation-starter.md"
vm_template_report="${state_root}/windows-vm-template.md"
state_report="${state_root}/windows-workflow-state.md"
hub_report="${state_root}/windows-workflow-hub.md"

if [[ -z "${selected_profile_id}" ]]; then
    selected_profile_id="adobe-creator"
fi

selected_row="$(awk -F'|' -v target="${selected_profile_id}" 'NF >= 8 && $1 == target {print; exit}' "${profiles_path}" || true)"
if [[ -z "${selected_row}" ]]; then
    printf 'Unknown Windows profile id: %s\n' "${selected_profile_id}" >&2
    exit 1
fi

IFS='|' read -r profile_id profile_name focus app_ids basic_route vm_route studio_route notes <<< "${selected_row}"

/usr/local/bin/ahmados-windows-vm-template --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

workspace_root="${documents_root}/Lumina Windows Workflows/${profile_id}"
checklists_dir="${workspace_root}/checklists"
actions_dir="${workspace_root}/actions"
installers_dir="${workspace_root}/installers"
vm_share_dir="${workspace_root}/vm-share"
workflow_state_root="${workspace_root}/state"
mkdir -p "${checklists_dir}" "${actions_dir}" "${installers_dir}" "${vm_share_dir}" "${workflow_state_root}"

template_env_path="${workspace_root}/vm-template.env"
if [[ -f "${template_env_path}" ]]; then
    # shellcheck disable=SC1090
    source "${template_env_path}"
fi

vm_name="${LUMINA_WINDOWS_VM_NAME:-Lumina-${profile_id//-/_}-vm}"
firmware="${LUMINA_WINDOWS_VM_FIRMWARE:-OVMF (UEFI)}"
cpu_topology="${LUMINA_WINDOWS_VM_CPU:-4 vCPU}"
memory_size="${LUMINA_WINDOWS_VM_MEMORY:-8 GiB}"
disk_size="${LUMINA_WINDOWS_VM_DISK:-100 GiB}"
share_name="${LUMINA_WINDOWS_VM_SHARE_NAME:-${profile_id//-/_}_share}"
share_path="${LUMINA_WINDOWS_VM_SHARE_PATH:-${vm_share_dir}}"

starter_marker="${workflow_state_root}/vm-creation-starter-ready.marker"
starter_plan_path="${workspace_root}/vm-create-plan.md"
starter_env_path="${workspace_root}/vm-create.env"
starter_checklist_path="${checklists_dir}/vm-create-checklist.md"
virt_install_example_path="${actions_dir}/15-virt-install-example.sh"

windows_iso_path="${installers_dir}/windows.iso"
virtio_iso_path="${installers_dir}/virtio-win.iso"
disk_path="${workspace_root}/${vm_name}.qcow2"

{
    printf 'LUMINA_WINDOWS_VM_NAME=%q\n' "${vm_name}"
    printf 'LUMINA_WINDOWS_VM_DISK_PATH=%q\n' "${disk_path}"
    printf 'LUMINA_WINDOWS_VM_WINDOWS_ISO=%q\n' "${windows_iso_path}"
    printf 'LUMINA_WINDOWS_VM_VIRTIO_ISO=%q\n' "${virtio_iso_path}"
    printf 'LUMINA_WINDOWS_VM_SHARE_NAME=%q\n' "${share_name}"
    printf 'LUMINA_WINDOWS_VM_SHARE_PATH=%q\n' "${share_path}"
    printf 'LUMINA_WINDOWS_VM_CPU=%q\n' "${cpu_topology}"
    printf 'LUMINA_WINDOWS_VM_MEMORY=%q\n' "${memory_size}"
    printf 'LUMINA_WINDOWS_VM_DISK=%q\n' "${disk_size}"
    printf 'LUMINA_WINDOWS_VM_FIRMWARE=%q\n' "${firmware}"
} > "${starter_env_path}"

cat > "${virt_install_example_path}" <<EOF
#!/usr/bin/env bash
set -euo pipefail

if [[ ! -f "${starter_env_path}" ]]; then
    printf 'Missing starter env: %s\n' "${starter_env_path}" >&2
    exit 1
fi

# shellcheck disable=SC1090
source "${starter_env_path}"

if [[ ! -f "\${LUMINA_WINDOWS_VM_WINDOWS_ISO}" ]]; then
    printf 'Place your Windows ISO at: %s\n' "\${LUMINA_WINDOWS_VM_WINDOWS_ISO}" >&2
    exit 1
fi

printf '%s\n' 'This is a starter command example. Review it before you run it.'
printf '%s\n' ''
printf 'virt-install \\\n'
printf '  --name %q \\\n' "\${LUMINA_WINDOWS_VM_NAME}"
printf '  --memory 8192 \\\n'
printf '  --vcpus 4 \\\n'
printf '  --cpu host-passthrough \\\n'
printf '  --machine q35 \\\n'
printf '  --os-variant win11 \\\n'
printf '  --boot uefi \\\n'
printf '  --disk path=%q,size=100,format=qcow2,bus=virtio \\\n' "\${LUMINA_WINDOWS_VM_DISK_PATH}"
printf '  --cdrom %q \\\n' "\${LUMINA_WINDOWS_VM_WINDOWS_ISO}"
printf '  --network network=default,model=virtio \\\n'
printf '  --graphics spice \\\n'
printf '  --channel spicevmc \\\n'
printf '  --filesystem source=%q,target=%q,driver.type=virtiofs \\\n' "\${LUMINA_WINDOWS_VM_SHARE_PATH}" "\${LUMINA_WINDOWS_VM_SHARE_NAME}"
printf '  --tpm backend.type=emulator,backend.version=2.0,model=tpm-crb \\\n'
printf '  --noautoconsole\n'
EOF
chmod 755 "${virt_install_example_path}"

{
    printf '# %s VM Creation Checklist\n\n' "${profile_name}"
    printf -- '- Confirm your trusted Windows ISO is present at `%s`\n' "${windows_iso_path}"
    printf -- '- Add `virtio-win.iso` if you plan to use virtio storage/network from the first install.\n'
    printf -- '- Review `%s`\n' "${workspace_root}/vm-template.md"
    printf -- '- Confirm the VM name `%s` and disk path `%s`\n' "${vm_name}" "${disk_path}"
    printf -- '- Confirm the share `%s` maps to `%s`\n' "${share_name}" "${share_path}"
    printf -- '- Decide whether you will start with `virt-manager` or the example `virt-install` command.\n'
    printf -- '- Create the VM only after the template and recipe both look sane.\n'
} > "${starter_checklist_path}"

{
    printf '# %s VM Creation Starter\n\n' "${profile_name}"
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Profile Id: %s\n' "${profile_id}"
    printf -- '- VM Name: %s\n' "${vm_name}"
    printf -- '- Firmware: %s\n' "${firmware}"
    printf -- '- CPU: %s\n' "${cpu_topology}"
    printf -- '- Memory: %s\n' "${memory_size}"
    printf -- '- Disk Size: %s\n' "${disk_size}"
    printf '\n## Asset Locations\n'
    printf -- '- Windows ISO Path: %s\n' "${windows_iso_path}"
    printf -- '- VirtIO ISO Path: %s\n' "${virtio_iso_path}"
    printf -- '- VM Disk Path: %s\n' "${disk_path}"
    printf -- '- Share Name: %s\n' "${share_name}"
    printf -- '- Share Path: %s\n' "${share_path}"
    printf '\n## Recommended Creation Flow\n'
    printf -- '- Start with a clean VM from the template, not from ad-hoc guesses.\n'
    printf -- '- Use virt-manager if you want the safest guided setup path first.\n'
    printf -- '- Use the example script only after you review and adjust it for your environment.\n'
    printf -- '- Mark `vm-created` only after the VM actually exists and boots into installation media.\n'
    printf '\n## Starter Files\n'
    printf -- '- VM Template: %s\n' "${workspace_root}/vm-template.md"
    printf -- '- Starter Env: %s\n' "${starter_env_path}"
    printf -- '- Starter Checklist: %s\n' "${starter_checklist_path}"
    printf -- '- Example Script: %s\n' "${virt_install_example_path}"
    printf -- '- VM Template Report: %s\n' "${vm_template_report}"
} > "${starter_plan_path}"

touch "${starter_marker}"
/usr/local/bin/ahmados-windows-workflow-state --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

{
    printf '# Lumina Windows VM Creation Starter\n\n'
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Profile: %s\n' "${profile_name}"
    printf -- '- Profile Id: %s\n' "${profile_id}"
    printf -- '- Starter Plan: %s\n' "${starter_plan_path}"
    printf -- '- Starter Env: %s\n' "${starter_env_path}"
    printf -- '- Starter Checklist: %s\n' "${starter_checklist_path}"
    printf -- '- Example Script: %s\n' "${virt_install_example_path}"
    printf -- '- Starter Marker: %s\n' "${starter_marker}"
    printf '\n## Related Reports\n'
    printf -- '- VM Template Report: %s\n' "${vm_template_report}"
    printf -- '- Workflow State Report: %s\n' "${state_report}"
    printf -- '- Workflow Hub Report: %s\n' "${hub_report}"
} > "${starter_report}"

printf '%s\n' '========================================'
printf '%s\n' '   Lumina Windows VM Creation Starter'
printf '%s\n' '========================================'
printf '\n'
printf 'Profile: %s\n' "${profile_name}"
printf 'Starter plan: %s\n' "${starter_plan_path}"
printf 'Report: %s\n' "${starter_report}"
printf '\n'

if [[ ${open_report} -eq 1 ]] && command -v xdg-open >/dev/null 2>&1; then
    xdg-open "${starter_report}" >/dev/null 2>&1 || true
fi
