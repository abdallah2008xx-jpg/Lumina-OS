#!/usr/bin/env bash
set -euo pipefail

selected_profile_id=""
open_report=1
list_only=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile-id)
            selected_profile_id="${2:-}"
            shift 2
            ;;
        --no-open)
            open_report=0
            shift
            ;;
        --list)
            list_only=1
            shift
            ;;
        *)
            printf 'Unknown argument: %s\n' "$1" >&2
            exit 1
            ;;
    esac
done

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/ahmados"
documents_root="${XDG_DOCUMENTS_DIR:-$HOME/Documents}"
mkdir -p "${state_root}"

profiles_path="/usr/share/lumina/windows-apps/profiles.tsv"
hub_report="${state_root}/windows-workflow-hub.md"
bridge_report="${state_root}/windows-apps-bridge.md"
compat_report="${state_root}/windows-compat-report.md"
profile_report="${state_root}/windows-profile-assistant.md"
runbook_report="${state_root}/windows-profile-runbook.md"
bootstrap_report="${state_root}/windows-workflow-bootstrap.md"
state_report="${state_root}/windows-workflow-state.md"
recipe_report="${state_root}/windows-workflow-recipe.md"
action_pack_report="${state_root}/windows-workflow-action-pack.md"
next_action_report="${state_root}/windows-workflow-next-action.md"
vm_template_report="${state_root}/windows-vm-template.md"
vm_creation_report="${state_root}/windows-vm-creation-starter.md"
vm_postcreate_report="${state_root}/windows-vm-postcreate.md"
app_install_report="${state_root}/windows-app-install-starter.md"
app_registration_report="${state_root}/windows-app-registration.md"
app_launcher_pack_report="${state_root}/windows-app-launcher-pack.md"
app_surfaces_report="${state_root}/windows-app-surfaces.md"
app_menu_export_report="${state_root}/windows-app-menu-export.md"
installed_app_sync_report="${state_root}/windows-installed-app-sync.md"
guest_app_publish_pack_report="${state_root}/windows-guest-app-publish-pack.md"
app_publish_sync_report="${state_root}/windows-app-publish-sync.md"
app_collections_report="${state_root}/windows-app-collections.md"
collection_menu_export_report="${state_root}/windows-collection-menu-export.md"
app_library_report="${state_root}/windows-app-library.md"
daily_menu_export_report="${state_root}/windows-daily-menu-export.md"
daily_app_pack_report="${state_root}/windows-daily-app-pack.md"
daily_app_picker_report="${state_root}/windows-daily-app-picker.md"
daily_runtime_report="${state_root}/windows-daily-runtime.md"
daily_recent_report="${state_root}/windows-daily-recent-sync.md"
daily_quick_launch_report="${state_root}/windows-daily-quick-launch.md"
workflow_proof_report="${state_root}/windows-workflow-proof-pass.md"
guest_agent_pack_report="${state_root}/windows-guest-agent-pack.md"
vm_warm_start_report="${state_root}/windows-vm-warm-start.md"
launch_sync_report="${state_root}/windows-launch-results-sync.md"
guest_onboarding_report="${state_root}/windows-guest-onboarding.md"
guest_app_discovery_report="${state_root}/windows-guest-app-discovery.md"
app_manifest_hydration_report="${state_root}/windows-app-manifest-hydration.md"

if [[ ${list_only} -eq 1 ]]; then
    awk -F'|' 'NF >= 3 && $1 !~ /^#/ {printf "%s\t%s\t%s\n", $1, $2, $3}' "${profiles_path}"
    exit 0
fi

choose_profile_with_kdialog() {
    local entries=()

    while IFS='|' read -r profile_id profile_name focus _; do
        [[ -z "${profile_id}" || "${profile_id}" == \#* ]] && continue
        entries+=("${profile_id}" "${profile_name} - ${focus}")
    done < "${profiles_path}"

    if [[ ${#entries[@]} -eq 0 ]]; then
        return 1
    fi

    kdialog --title "Lumina Windows Apps" \
        --menu "Choose the Windows workflow you want Lumina to guide from one place." \
        "${entries[@]}" 2>/dev/null || return 1
}

if [[ -z "${selected_profile_id}" ]] && command -v kdialog >/dev/null 2>&1 && [[ -n "${DISPLAY:-}" ]]; then
    selected_profile_id="$(choose_profile_with_kdialog || true)"
fi

if [[ -z "${selected_profile_id}" ]]; then
    selected_profile_id="adobe-creator"
fi

selected_row="$(awk -F'|' -v target="${selected_profile_id}" 'NF >= 8 && $1 == target {print; exit}' "${profiles_path}" || true)"
if [[ -z "${selected_row}" ]]; then
    printf 'Unknown Windows profile id: %s\n' "${selected_profile_id}" >&2
    exit 1
fi

IFS='|' read -r profile_id profile_name focus app_ids basic_route vm_route studio_route notes <<< "${selected_row}"

/usr/local/bin/ahmados-windows-apps --no-open >/dev/null 2>&1 || true
/usr/local/bin/ahmados-windows-profile-assistant --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true
/usr/local/bin/ahmados-windows-workflow-action-pack --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true
/usr/local/bin/ahmados-windows-vm-template --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true
/usr/local/bin/ahmados-windows-vm-creation-starter --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true
/usr/local/bin/ahmados-windows-vm-postcreate --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true
/usr/local/bin/ahmados-windows-app-install-starter --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true
/usr/local/bin/ahmados-windows-launch-results-sync --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

workspace_root="${documents_root}/Lumina Windows Workflows/${profile_id}"
workflow_state_root="${workspace_root}/state"

bootstrap_marker="${workflow_state_root}/bootstrap-ready.marker"
launch_recipe_marker="${workflow_state_root}/launch-recipe-ready.marker"
action_pack_marker="${workflow_state_root}/action-pack-ready.marker"
vm_template_marker="${workflow_state_root}/vm-template-ready.marker"
vm_creation_marker="${workflow_state_root}/vm-creation-starter-ready.marker"
vm_postcreate_marker="${workflow_state_root}/vm-postcreate-ready.marker"
app_install_marker="${workflow_state_root}/app-install-starter-ready.marker"
app_registration_marker="${workflow_state_root}/app-registration-ready.marker"
app_launcher_pack_marker="${workflow_state_root}/app-launcher-pack-ready.marker"
app_surfaces_marker="${workflow_state_root}/app-surfaces-ready.marker"
app_menu_export_marker="${workflow_state_root}/app-menu-export-ready.marker"
installed_app_sync_marker="${workflow_state_root}/installed-app-sync-ready.marker"
guest_app_publish_pack_marker="${workflow_state_root}/guest-app-publish-pack-ready.marker"
app_publish_sync_marker="${workflow_state_root}/app-publish-sync-ready.marker"
app_collections_marker="${workflow_state_root}/app-collections-ready.marker"
collection_menu_export_marker="${workflow_state_root}/collection-menu-export-ready.marker"
app_library_marker="${workflow_state_root}/app-library-ready.marker"
daily_menu_export_marker="${workflow_state_root}/daily-menu-export-ready.marker"
daily_app_pack_marker="${workflow_state_root}/daily-app-pack-ready.marker"
daily_recent_marker="${workflow_state_root}/daily-recent-ready.marker"
daily_quick_launch_marker="${workflow_state_root}/daily-quick-launch-ready.marker"
workflow_proof_marker="${workflow_state_root}/workflow-proof-ready.marker"
guest_agent_pack_marker="${workflow_state_root}/guest-agent-pack-ready.marker"
launch_result_seen_marker="${workflow_state_root}/launch-result-seen.marker"
launch_request_pending_marker="${workflow_state_root}/launch-request-pending.marker"
launch_queue_pressure_marker="${workflow_state_root}/launch-queue-pressure.marker"
launch_queue_cleanup_marker="${workflow_state_root}/launch-queue-cleanup.marker"
guest_onboarding_marker="${workflow_state_root}/guest-onboarding-ready.marker"
guest_agent_installed_marker="${workflow_state_root}/guest-agent-installed.marker"
guest_app_discovery_marker="${workflow_state_root}/guest-app-discovery-ready.marker"
app_manifest_hydration_marker="${workflow_state_root}/app-manifest-hydration-ready.marker"
vm_created_marker="${workflow_state_root}/vm-created.marker"
vm_configured_marker="${workflow_state_root}/vm-configured.marker"
apps_installed_marker="${workflow_state_root}/apps-installed.marker"
checklist_complete_marker="${workflow_state_root}/checklist-complete.marker"
linux_first_validated_marker="${workflow_state_root}/linux-first-validated.marker"

experience_mode="$(awk -F': ' '/^- Experience Mode:/ {print $2; exit}' "${bridge_report}" 2>/dev/null || true)"
compatibility_tier="$(awk -F': ' '/^- Compatibility Tier:/ {print $2; exit}' "${compat_report}" 2>/dev/null || true)"
resource_class="$(awk -F': ' '/^- Resource Class:/ {print $2; exit}' "${compat_report}" 2>/dev/null || true)"
resource_summary="$(awk -F': ' '/^- Resource Summary:/ {print $2; exit}' "${compat_report}" 2>/dev/null || true)"
recommended_route="$(awk -F': ' '/^- Recommended Route:/ {print $2; exit}' "${profile_report}" 2>/dev/null || true)"
current_phase="$(awk -F': ' '/^- Current Phase:/ {print $2; exit}' "${state_report}" 2>/dev/null || true)"
workflow_status="$(awk -F': ' '/^- Status:/ {print $2; exit}' "${state_report}" 2>/dev/null || true)"
warm_start_status="$(awk -F': ' '/^- Warm Start Status:/ {print $2; exit}' "${vm_warm_start_report}" 2>/dev/null || true)"
pressure_state="$(awk -F': ' '/^- Pressure State:/ {print $2; exit}' "${vm_warm_start_report}" 2>/dev/null || true)"
workflow_guard="$(awk -F': ' '/^- Workflow Guard:/ {print $2; exit}' "${vm_warm_start_report}" 2>/dev/null || true)"
launch_queue_health="$(awk -F': ' '/^- Launch Queue Health:/ {print $2; exit}' "${launch_sync_report}" 2>/dev/null || true)"
queue_note="$(awk -F': ' '/^- Queue Note:/ {print $2; exit}' "${launch_sync_report}" 2>/dev/null || true)"
stale_requests_moved="$(awk -F': ' '/^- Stale Pending Requests Moved:/ {print $2; exit}' "${launch_sync_report}" 2>/dev/null || true)"
daily_recent_ready="$(awk -F': ' '/^- Recent App Ready:/ {print $2; exit}' "${daily_recent_report}" 2>/dev/null || true)"
daily_recent_app_name="$(awk -F': ' '/^- Recent App Name:/ {print $2; exit}' "${daily_recent_report}" 2>/dev/null || true)"
daily_quick_launch_mode="$(awk -F': ' '/^- Quick Launch Mode:/ {print $2; exit}' "${daily_quick_launch_report}" 2>/dev/null || true)"
daily_quick_launch_command="$(awk -F': ' '/^- Quick Launch Command:/ {print $2; exit}' "${daily_quick_launch_report}" 2>/dev/null || true)"
daily_quick_launch_outcome="$(awk -F': ' '/^- Launch Outcome:/ {print $2; exit}' "${daily_quick_launch_report}" 2>/dev/null || true)"
[[ -n "${launch_queue_health}" ]] || launch_queue_health="unknown"
[[ -n "${queue_note}" ]] || queue_note="No queue note captured."
[[ -n "${stale_requests_moved}" ]] || stale_requests_moved="0"
[[ -n "${daily_recent_ready}" ]] || daily_recent_ready="no"
[[ -n "${daily_recent_app_name}" ]] || daily_recent_app_name="none"
[[ -n "${daily_quick_launch_mode}" ]] || daily_quick_launch_mode="unknown"
[[ -n "${daily_quick_launch_command}" ]] || daily_quick_launch_command="none"
[[ -n "${daily_quick_launch_outcome}" ]] || daily_quick_launch_outcome="not-run"

if [[ -z "${recommended_route}" ]]; then
    recommended_route="${basic_route}"
fi

route_mode="linux-first"
if [[ "${recommended_route}" == *"Out of scope"* ]]; then
    route_mode="out-of-scope"
elif [[ "${recommended_route}" == *"GPU focus"* ]]; then
    route_mode="studio-vm"
elif [[ "${recommended_route}" == *"Windows VM"* ]]; then
    route_mode="windows-vm"
fi

next_action="Review the workflow reports"
next_command="xdg-open '${profile_report}'"
operator_note="Stay Lumina-first and move only one layer at a time."
runtime_guard_note=""

if [[ "${resource_class}" == "light" && "${route_mode}" != "linux-first" && -f "${vm_created_marker}" && "${warm_start_status}" == "already-running" && ! -f "${launch_request_pending_marker}" ]]; then
    next_action="Cool down the idle Windows workspace"
    next_command="/usr/local/bin/lumina-windows-vm-runner --profile-id ${profile_id} --cooldown"
    operator_note="This Windows workspace is already warm on a light machine and no launch is pending, so reclaiming resources is the smoothest next move."
elif [[ "${resource_class}" == "light" && -f "${launch_queue_pressure_marker}" ]]; then
    next_action="Clear and sync the Windows launch queue"
    next_command="/usr/local/bin/lumina-windows-launch-results-sync --profile-id ${profile_id}"
    operator_note="Multiple staged launch requests are piling up on a light machine, so Lumina should sync and shrink the queue before opening more Windows load."
elif [[ "${resource_class}" == "light" && "${route_mode}" == "linux-first" && ! -f "${linux_first_validated_marker}" ]]; then
    next_action="Validate the Linux-first route"
    next_command="/usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step linux-first-validated"
    operator_note="This machine is light, so the safest next move is to prove the Linux-first route before expanding Windows background load."
elif [[ "${resource_class}" == "light" && "${pressure_state}" == "guarded-lightweight" && "${workflow_guard}" == "single-workflow" ]]; then
    next_action="Review the lightweight app library"
    next_command="/usr/local/bin/lumina-windows-app-library --profile-id ${profile_id}"
    operator_note="Lightweight guard is active, so Lumina should keep the user on lighter app sets before adding more Windows load."
elif [[ ! -f "${bootstrap_marker}" ]]; then
    next_action="Prepare the Lumina-side workspace"
    next_command="/usr/local/bin/lumina-windows-workflow-bootstrap --profile-id ${profile_id}"
    operator_note="Create the folders, names, and checklists first so the workflow has a stable home."
elif [[ ! -f "${launch_recipe_marker}" ]]; then
    next_action="Generate the daily launch recipe"
    next_command="/usr/local/bin/lumina-windows-workflow-recipe --profile-id ${profile_id}"
    operator_note="This turns the workflow from setup notes into a repeatable operating rhythm."
elif [[ ! -f "${action_pack_marker}" ]]; then
    next_action="Generate the workspace action pack"
    next_command="/usr/local/bin/lumina-windows-workflow-action-pack --profile-id ${profile_id}"
    operator_note="This gives the workspace ready-to-use helper scripts instead of making the user memorize commands."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${vm_template_marker}" ]]; then
    next_action="Generate the VM template"
    next_command="/usr/local/bin/lumina-windows-vm-template --profile-id ${profile_id}"
    operator_note="This defines the VM shape clearly before the actual Windows workspace gets created."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${vm_creation_marker}" ]]; then
    next_action="Generate the VM creation starter"
    next_command="/usr/local/bin/lumina-windows-vm-creation-starter --profile-id ${profile_id}"
    operator_note="This prepares the actual creation plan, env, checklist, and starter command skeleton before the VM exists."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${vm_postcreate_marker}" ]]; then
    next_action="Generate the VM post-create workflow"
    next_command="/usr/local/bin/lumina-windows-vm-postcreate --profile-id ${profile_id}"
    operator_note="This prepares the first-boot, VirtIO, share-validation, and snapshot guidance before the VM gets treated as configured."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${guest_agent_pack_marker}" ]]; then
    next_action="Generate the guest agent pack"
    next_command="/usr/local/bin/lumina-windows-guest-agent-pack --profile-id ${profile_id}"
    operator_note="This prepares the Windows-side launch contract so staged EXE requests can eventually be consumed inside the guest."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${guest_onboarding_marker}" ]]; then
    next_action="Generate the guest onboarding plan"
    next_command="/usr/local/bin/lumina-windows-guest-onboarding --profile-id ${profile_id}"
    operator_note="This turns the generated guest agent pack into a concrete Windows-side install checklist instead of leaving the handoff vague."
elif [[ "${route_mode}" != "out-of-scope" && -f "${launch_request_pending_marker}" ]]; then
    next_action="Sync launch results"
    next_command="/usr/local/bin/lumina-windows-launch-results-sync --profile-id ${profile_id}"
    operator_note="A staged request is pending. Sync the shared results so Lumina can see whether the guest consumed it yet."
elif [[ "${route_mode}" != "out-of-scope" && -f "${launch_result_seen_marker}" && ! -f "${guest_agent_installed_marker}" ]]; then
    next_action="Mark the guest agent as installed"
    next_command="/usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step guest-agent-installed"
    operator_note="Lumina has already seen guest-side launch proof, so this is the right moment to close the guest-agent install gate."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_install_marker}" ]]; then
    next_action="Generate the app install starter"
    next_command="/usr/local/bin/lumina-windows-app-install-starter --profile-id ${profile_id}"
    operator_note="This prepares the core app stack order, installer notes, and the checklist for the first working software pass."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_registration_marker}" ]]; then
    next_action="Generate app registration manifests"
    next_command="/usr/local/bin/lumina-windows-app-registration --profile-id ${profile_id}"
    operator_note="This records named app manifests so proof passes validate known apps instead of anonymous install steps."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${guest_app_discovery_marker}" ]]; then
    next_action="Generate guest app discovery pack"
    next_command="/usr/local/bin/lumina-windows-guest-app-discovery --profile-id ${profile_id}"
    operator_note="This prepares the Windows-side discovery pass that can find real installed app targets for the registered app set."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_manifest_hydration_marker}" ]]; then
    next_action="Hydrate app manifests from guest discovery"
    next_command="/usr/local/bin/lumina-windows-app-manifest-hydration --profile-id ${profile_id}"
    operator_note="This fills the registered app manifests with real launch targets from the latest Windows-side discovery results."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_launcher_pack_marker}" ]]; then
    next_action="Generate app launcher pack"
    next_command="/usr/local/bin/lumina-windows-app-launcher-pack --profile-id ${profile_id}"
    operator_note="This turns the registered app manifests into concrete launch surfaces inside the workflow workspace."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_surfaces_marker}" ]]; then
    next_action="Generate app surfaces"
    next_command="/usr/local/bin/lumina-windows-app-surfaces --profile-id ${profile_id}"
    operator_note="This indexes the registered app launch surfaces so Lumina can treat known Windows apps as named launchable entities."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_menu_export_marker}" ]]; then
    next_action="Export app launchers into the Lumina menu"
    next_command="/usr/local/bin/lumina-windows-app-menu-export --profile-id ${profile_id}"
    operator_note="This makes the registered Windows apps show up as real Lumina menu entries instead of staying trapped inside workspace files."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${installed_app_sync_marker}" ]]; then
    next_action="Run installed-app sync and launcher refresh"
    next_command="/usr/local/bin/lumina-windows-installed-app-sync --profile-id ${profile_id}"
    operator_note="This consolidates launch results, guest discovery, manifest hydration, launcher refresh, and menu export into one refresh pass."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${guest_app_publish_pack_marker}" ]]; then
    next_action="Generate the guest app publish pack"
    next_command="/usr/local/bin/lumina-windows-guest-app-publish-pack --profile-id ${profile_id}"
    operator_note="This prepares the Windows-side publish contract so discovered app targets become a stronger published inventory for Lumina."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_publish_sync_marker}" ]]; then
    next_action="Sync the published app inventory"
    next_command="/usr/local/bin/lumina-windows-app-publish-sync --profile-id ${profile_id}"
    operator_note="Run the generated publish runner inside Windows first, then use this sync so Lumina absorbs the stronger guest-side inventory."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_collections_marker}" ]]; then
    next_action="Generate app collections"
    next_command="/usr/local/bin/lumina-windows-app-collections --profile-id ${profile_id}"
    operator_note="This groups the registered apps into Lumina-facing collections instead of leaving everything at the individual launcher level."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${collection_menu_export_marker}" ]]; then
    next_action="Export collection launchers into the Lumina menu"
    next_command="/usr/local/bin/lumina-windows-collection-menu-export --profile-id ${profile_id}"
    operator_note="This promotes the named Windows app collections into the Lumina menu so they feel like first-class Lumina launch surfaces."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_library_marker}" ]]; then
    next_action="Generate the Windows app library view"
    next_command="/usr/local/bin/lumina-windows-app-library --profile-id ${profile_id}"
    operator_note="This builds a single Lumina-facing library view for published apps, discovered apps, and collections so the experience stops feeling like scattered reports."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${workflow_proof_marker}" ]]; then
    next_action="Generate the workflow proof pass"
    next_command="/usr/local/bin/lumina-windows-workflow-proof-pass --profile-id ${profile_id}"
    operator_note="This prepares the first real proof pass after the core app stack, app registration, and app surfaces are ready."
elif [[ "${route_mode}" == "out-of-scope" ]]; then
    next_action="Keep this workflow documented, not promised"
    next_command="xdg-open '${recipe_report}'"
    operator_note="Do not market unsupported anti-cheat or stealth-sensitive paths as solved."
elif [[ "${route_mode}" == "linux-first" && ! -f "${linux_first_validated_marker}" ]]; then
    next_action="Validate the Linux-first route"
    next_command="/usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step linux-first-validated"
    operator_note="Only mark this after one realistic workflow pass feels good enough on the Lumina side."
elif [[ "${route_mode}" != "linux-first" && ! -f "${vm_created_marker}" ]]; then
    next_action="Create the Windows workspace VM"
    next_command="/usr/local/bin/lumina-windows-vm-launcher --profile-id ${profile_id}"
    operator_note="The VM launcher will create a real VM and open virt-manager automatically."
elif [[ "${route_mode}" != "linux-first" && ! -f "${vm_configured_marker}" ]]; then
    next_action="Configure the Windows VM"
    next_command="/usr/local/bin/lumina-windows-auto-configure --profile-id ${profile_id}"
    operator_note="The auto-configure tool will check networking, shares, and snapshots, then offer to mark the VM as configured."
elif [[ "${route_mode}" != "linux-first" && ! -f "${apps_installed_marker}" ]]; then
    next_action="Follow the app install starter"
    next_command="xdg-open '${app_install_report}'"
    operator_note="Use the app install plan to get through the first core app stack before you mark the workflow as apps-installed."
elif [[ "${route_mode}" != "out-of-scope" && -f "${app_library_marker}" && -f "${workflow_proof_marker}" && -f "${checklist_complete_marker}" && "${resource_class}" == "light" && -f "${daily_recent_marker}" ]]; then
    next_action="Run the daily quick-launch path"
    next_command="/usr/local/bin/lumina-windows-daily-quick-launch --profile-id ${profile_id} --launch"
    operator_note="This workflow already has a fast daily path, so on a light machine Lumina should reopen that direct route first."
elif [[ "${route_mode}" != "out-of-scope" && -f "${app_library_marker}" && -f "${workflow_proof_marker}" && -f "${checklist_complete_marker}" ]]; then
    next_action="Run the daily quick-launch path"
    next_command="/usr/local/bin/lumina-windows-daily-quick-launch --profile-id ${profile_id} --launch"
    operator_note="This workflow is ready enough for daily use, so Lumina can now reopen the smoothest daily route directly instead of sending the user back into setup reports."
elif [[ ! -f "${checklist_complete_marker}" ]]; then
    next_action="Follow the workflow proof pass"
    next_command="xdg-open '${workflow_proof_report}'"
    operator_note="Use the proof pass to validate launch, save, export, and share behavior before you close the checklist."
else
    next_action="Workflow ready for the next stage"
    next_command="xdg-open '${recipe_report}'"
    operator_note="At this point the workflow has a stable Lumina-side home, a repeatable rhythm, and a tracked state."
fi

if [[ "${resource_class}" == "light" ]]; then
    runtime_guard_note="Lightweight mode is active. Keep one Windows workflow warm at a time and prefer Linux-first launches whenever possible."
elif [[ "${resource_class}" == "performance" ]]; then
    runtime_guard_note="Performance mode is available, but Lumina should still avoid pointless background Windows load."
fi

{
    printf '# Lumina Windows Workflow Hub\n\n'
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Profile: %s\n' "${profile_name}"
    printf -- '- Profile Id: %s\n' "${profile_id}"
    printf -- '- Focus: %s\n' "${focus}"
    printf -- '- Experience Mode: %s\n' "${experience_mode:-unknown}"
    printf -- '- Compatibility Tier: %s\n' "${compatibility_tier:-unknown}"
    printf -- '- Resource Class: %s\n' "${resource_class:-unknown}"
    printf -- '- Resource Summary: %s\n' "${resource_summary:-unknown}"
    printf -- '- Recommended Route: %s\n' "${recommended_route}"
    printf -- '- Current Phase: %s\n' "${current_phase:-unknown}"
    printf -- '- Workflow Status: %s\n' "${workflow_status:-unknown}"
    printf -- '- Warm Start Status: %s\n' "${warm_start_status:-not-run}"
    printf -- '- Pressure State: %s\n' "${pressure_state:-unknown}"
    printf -- '- Workflow Guard: %s\n' "${workflow_guard:-unknown}"
    printf -- '- Launch Queue Health: %s\n' "${launch_queue_health}"
    printf -- '- Daily Recent Ready: %s\n' "${daily_recent_ready}"
    printf -- '- Daily Recent App: %s\n' "${daily_recent_app_name}"
    printf -- '- Daily Quick Launch Mode: %s\n' "${daily_quick_launch_mode}"
    printf -- '- Daily Quick Launch Outcome: %s\n' "${daily_quick_launch_outcome}"
    printf -- '- Daily Quick Launch Command: `%s`\n' "${daily_quick_launch_command}"
    printf '\n## Next Action\n'
    printf -- '- %s\n' "${next_action}"
    printf -- '- Suggested Command: `%s`\n' "${next_command}"
    printf -- '- Operator Note: %s\n' "${operator_note}"
    if [[ -n "${runtime_guard_note}" ]]; then
        printf -- '- Runtime Guard Note: %s\n' "${runtime_guard_note}"
    fi
    printf -- '- Queue Note: %s\n' "${queue_note}"
    printf '\n## Marker Snapshot\n'
    printf -- '- Bootstrap Ready: %s\n' "$([[ -f "${bootstrap_marker}" ]] && printf yes || printf no)"
    printf -- '- Launch Recipe Ready: %s\n' "$([[ -f "${launch_recipe_marker}" ]] && printf yes || printf no)"
    printf -- '- Action Pack Ready: %s\n' "$([[ -f "${action_pack_marker}" ]] && printf yes || printf no)"
    printf -- '- VM Template Ready: %s\n' "$([[ -f "${vm_template_marker}" ]] && printf yes || printf no)"
    printf -- '- VM Creation Starter Ready: %s\n' "$([[ -f "${vm_creation_marker}" ]] && printf yes || printf no)"
    printf -- '- VM Post-Create Ready: %s\n' "$([[ -f "${vm_postcreate_marker}" ]] && printf yes || printf no)"
    printf -- '- App Install Starter Ready: %s\n' "$([[ -f "${app_install_marker}" ]] && printf yes || printf no)"
    printf -- '- App Registration Ready: %s\n' "$([[ -f "${app_registration_marker}" ]] && printf yes || printf no)"
    printf -- '- App Launcher Pack Ready: %s\n' "$([[ -f "${app_launcher_pack_marker}" ]] && printf yes || printf no)"
    printf -- '- App Surfaces Ready: %s\n' "$([[ -f "${app_surfaces_marker}" ]] && printf yes || printf no)"
    printf -- '- App Menu Export Ready: %s\n' "$([[ -f "${app_menu_export_marker}" ]] && printf yes || printf no)"
    printf -- '- Installed App Sync Ready: %s\n' "$([[ -f "${installed_app_sync_marker}" ]] && printf yes || printf no)"
    printf -- '- Guest App Publish Pack Ready: %s\n' "$([[ -f "${guest_app_publish_pack_marker}" ]] && printf yes || printf no)"
    printf -- '- App Publish Sync Ready: %s\n' "$([[ -f "${app_publish_sync_marker}" ]] && printf yes || printf no)"
    printf -- '- App Collections Ready: %s\n' "$([[ -f "${app_collections_marker}" ]] && printf yes || printf no)"
    printf -- '- Collection Menu Export Ready: %s\n' "$([[ -f "${collection_menu_export_marker}" ]] && printf yes || printf no)"
    printf -- '- App Library Ready: %s\n' "$([[ -f "${app_library_marker}" ]] && printf yes || printf no)"
    printf -- '- Daily Menu Export Ready: %s\n' "$([[ -f "${daily_menu_export_marker}" ]] && printf yes || printf no)"
    printf -- '- Daily App Pack Ready: %s\n' "$([[ -f "${daily_app_pack_marker}" ]] && printf yes || printf no)"
    printf -- '- Daily Recent Ready: %s\n' "$([[ -f "${daily_recent_marker}" ]] && printf yes || printf no)"
    printf -- '- Daily Quick Launch Ready: %s\n' "$([[ -f "${daily_quick_launch_marker}" ]] && printf yes || printf no)"
    printf -- '- Workflow Proof Ready: %s\n' "$([[ -f "${workflow_proof_marker}" ]] && printf yes || printf no)"
    printf -- '- Guest Agent Pack Ready: %s\n' "$([[ -f "${guest_agent_pack_marker}" ]] && printf yes || printf no)"
    printf -- '- Guest Onboarding Ready: %s\n' "$([[ -f "${guest_onboarding_marker}" ]] && printf yes || printf no)"
    printf -- '- Guest Agent Installed: %s\n' "$([[ -f "${guest_agent_installed_marker}" ]] && printf yes || printf no)"
    printf -- '- Guest App Discovery Ready: %s\n' "$([[ -f "${guest_app_discovery_marker}" ]] && printf yes || printf no)"
    printf -- '- App Manifest Hydration Ready: %s\n' "$([[ -f "${app_manifest_hydration_marker}" ]] && printf yes || printf no)"
    printf -- '- Launch Result Seen: %s\n' "$([[ -f "${launch_result_seen_marker}" ]] && printf yes || printf no)"
    printf -- '- Launch Request Pending: %s\n' "$([[ -f "${launch_request_pending_marker}" ]] && printf yes || printf no)"
    printf -- '- Launch Queue Pressure: %s\n' "$([[ -f "${launch_queue_pressure_marker}" ]] && printf yes || printf no)"
