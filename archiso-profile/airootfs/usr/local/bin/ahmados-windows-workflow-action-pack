#!/usr/bin/env bash
set -euo pipefail

selected_profile_id=""
open_report=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile-id)
            selected_profile_id="${2:-}"
            shift 2
            ;;
        --no-open)
            open_report=0
            shift
            ;;
        *)
            printf 'Unknown argument: %s\n' "$1" >&2
            exit 1
            ;;
    esac
done

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/ahmados"
documents_root="${XDG_DOCUMENTS_DIR:-$HOME/Documents}"
mkdir -p "${state_root}"

profiles_path="/usr/share/lumina/windows-apps/profiles.tsv"
action_pack_report="${state_root}/windows-workflow-action-pack.md"
state_report="${state_root}/windows-workflow-state.md"
recipe_report="${state_root}/windows-workflow-recipe.md"
hub_report="${state_root}/windows-workflow-hub.md"
vm_template_report="${state_root}/windows-vm-template.md"
vm_creation_report="${state_root}/windows-vm-creation-starter.md"
vm_postcreate_report="${state_root}/windows-vm-postcreate.md"
app_install_report="${state_root}/windows-app-install-starter.md"
app_registration_report="${state_root}/windows-app-registration.md"
app_launcher_pack_report="${state_root}/windows-app-launcher-pack.md"
app_surfaces_report="${state_root}/windows-app-surfaces.md"
guest_app_discovery_report="${state_root}/windows-guest-app-discovery.md"
app_manifest_hydration_report="${state_root}/windows-app-manifest-hydration.md"
guest_app_publish_pack_report="${state_root}/windows-guest-app-publish-pack.md"
app_publish_sync_report="${state_root}/windows-app-publish-sync.md"
workflow_proof_report="${state_root}/windows-workflow-proof-pass.md"
launch_sync_report="${state_root}/windows-launch-results-sync.md"
guest_onboarding_report="${state_root}/windows-guest-onboarding.md"
collection_menu_export_report="${state_root}/windows-collection-menu-export.md"
app_library_report="${state_root}/windows-app-library.md"
daily_menu_export_report="${state_root}/windows-daily-menu-export.md"
daily_app_pack_report="${state_root}/windows-daily-app-pack.md"

if [[ -z "${selected_profile_id}" ]]; then
    selected_profile_id="adobe-creator"
fi

selected_row="$(awk -F'|' -v target="${selected_profile_id}" 'NF >= 8 && $1 == target {print; exit}' "${profiles_path}" || true)"
if [[ -z "${selected_row}" ]]; then
    printf 'Unknown Windows profile id: %s\n' "${selected_profile_id}" >&2
    exit 1
fi

IFS='|' read -r profile_id profile_name focus app_ids basic_route vm_route studio_route notes <<< "${selected_row}"

/usr/local/bin/ahmados-windows-workflow-recipe --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true
/usr/local/bin/ahmados-windows-vm-postcreate --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true
/usr/local/bin/ahmados-windows-app-install-starter --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

workspace_root="${documents_root}/Lumina Windows Workflows/${profile_id}"
actions_dir="${workspace_root}/actions"
notes_dir="${workspace_root}/notes"
vm_share_dir="${workspace_root}/vm-share"
checklists_dir="${workspace_root}/checklists"
summary_path="${workspace_root}/workspace-summary.md"
daily_recipe_path="${checklists_dir}/daily-launch-recipe.md"
vm_postcreate_plan_path="${workspace_root}/vm-postcreate-plan.md"
app_install_plan_path="${workspace_root}/app-install-plan.md"
workflow_state_root="${workspace_root}/state"
action_pack_marker="${workflow_state_root}/action-pack-ready.marker"
launchers_dir="${workspace_root}/app-registry/launchers"
menu_export_report="${state_root}/windows-app-menu-export.md"
installed_app_sync_report="${state_root}/windows-installed-app-sync.md"
app_collections_report="${state_root}/windows-app-collections.md"
menu_export_dir="${XDG_DATA_HOME:-$HOME/.local/share}/applications/lumina-windows-apps/${profile_id}"
collection_menu_export_dir="${XDG_DATA_HOME:-$HOME/.local/share}/applications/lumina-windows-collections/${profile_id}"
daily_menu_export_dir="${XDG_DATA_HOME:-$HOME/.local/share}/applications/lumina-windows-daily/${profile_id}"
daily_app_pack_dir="${XDG_DATA_HOME:-$HOME/.local/share}/applications/lumina-windows-daily-apps/${profile_id}"

mkdir -p "${actions_dir}" "${notes_dir}" "${vm_share_dir}" "${checklists_dir}" "${workflow_state_root}"

create_script() {
    local target_path="$1"
    local body="$2"

    cat > "${target_path}" <<EOF
#!/usr/bin/env bash
set -euo pipefail
${body}
EOF
    chmod 755 "${target_path}"
}

create_script "${actions_dir}/01-open-workflow-hub.sh" "exec /usr/local/bin/lumina-windows-workflow-hub --profile-id ${profile_id}"
create_script "${actions_dir}/02-do-next-action.sh" "exec /usr/local/bin/lumina-windows-workflow-next-action --profile-id ${profile_id}"
create_script "${actions_dir}/03-generate-vm-template.sh" "exec /usr/local/bin/lumina-windows-vm-template --profile-id ${profile_id}"
create_script "${actions_dir}/04-generate-vm-creation-starter.sh" "exec /usr/local/bin/lumina-windows-vm-creation-starter --profile-id ${profile_id}"
create_script "${actions_dir}/15-generate-vm-postcreate.sh" "exec /usr/local/bin/lumina-windows-vm-postcreate --profile-id ${profile_id}"
create_script "${actions_dir}/16-open-vm-postcreate-plan.sh" "exec xdg-open \"${vm_postcreate_plan_path}\""
create_script "${actions_dir}/17-generate-app-install-starter.sh" "exec /usr/local/bin/lumina-windows-app-install-starter --profile-id ${profile_id}"
create_script "${actions_dir}/18-open-app-install-plan.sh" "exec xdg-open \"${app_install_plan_path}\""
create_script "${actions_dir}/19-generate-workflow-proof-pass.sh" "exec /usr/local/bin/lumina-windows-workflow-proof-pass --profile-id ${profile_id}"
create_script "${actions_dir}/20-open-workflow-proof-plan.sh" "exec xdg-open \"${workspace_root}/workflow-proof-plan.md\""
create_script "${actions_dir}/21-generate-guest-agent-pack.sh" "exec /usr/local/bin/lumina-windows-guest-agent-pack --profile-id ${profile_id}"
create_script "${actions_dir}/22-warm-start-vm.sh" "exec /usr/local/bin/lumina-windows-vm-warm-start --profile-id ${profile_id}"
create_script "${actions_dir}/23-sync-launch-results.sh" "exec /usr/local/bin/lumina-windows-launch-results-sync --profile-id ${profile_id}"
create_script "${actions_dir}/24-open-launch-results-report.sh" "exec xdg-open \"${launch_sync_report}\""
create_script "${actions_dir}/25-generate-guest-onboarding.sh" "exec /usr/local/bin/lumina-windows-guest-onboarding --profile-id ${profile_id}"
create_script "${actions_dir}/26-mark-guest-agent-installed.sh" "exec /usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step guest-agent-installed"
create_script "${actions_dir}/27-open-guest-onboarding-report.sh" "exec xdg-open \"${guest_onboarding_report}\""
create_script "${actions_dir}/28-generate-app-registration.sh" "exec /usr/local/bin/lumina-windows-app-registration --profile-id ${profile_id}"
create_script "${actions_dir}/29-open-app-registration-report.sh" "exec xdg-open \"${app_registration_report}\""
create_script "${actions_dir}/30-generate-app-launcher-pack.sh" "exec /usr/local/bin/lumina-windows-app-launcher-pack --profile-id ${profile_id}"
create_script "${actions_dir}/31-open-app-launcher-pack-report.sh" "exec xdg-open \"${app_launcher_pack_report}\""
create_script "${actions_dir}/32-open-app-launchers-folder.sh" "exec xdg-open \"${launchers_dir}\""
create_script "${actions_dir}/33-generate-app-surfaces.sh" "exec /usr/local/bin/lumina-windows-app-surfaces --profile-id ${profile_id}"
create_script "${actions_dir}/34-open-app-surfaces-report.sh" "exec xdg-open \"${app_surfaces_report}\""
create_script "${actions_dir}/35-pick-registered-app.sh" "exec /usr/local/bin/lumina-windows-registered-app-picker --profile-id ${profile_id}"
create_script "${actions_dir}/36-generate-guest-app-discovery.sh" "exec /usr/local/bin/lumina-windows-guest-app-discovery --profile-id ${profile_id}"
create_script "${actions_dir}/37-open-guest-app-discovery-report.sh" "exec xdg-open \"${guest_app_discovery_report}\""
create_script "${actions_dir}/38-hydrate-app-manifests.sh" "exec /usr/local/bin/lumina-windows-app-manifest-hydration --profile-id ${profile_id}"
create_script "${actions_dir}/39-open-app-manifest-hydration-report.sh" "exec xdg-open \"${app_manifest_hydration_report}\""
create_script "${actions_dir}/40-export-app-menu-launchers.sh" "exec /usr/local/bin/lumina-windows-app-menu-export --profile-id ${profile_id}"
create_script "${actions_dir}/41-open-app-menu-export-report.sh" "exec xdg-open \"${menu_export_report}\""
create_script "${actions_dir}/42-open-app-menu-export-folder.sh" "exec xdg-open \"${menu_export_dir}\""
create_script "${actions_dir}/43-run-installed-app-sync.sh" "exec /usr/local/bin/lumina-windows-installed-app-sync --profile-id ${profile_id}"
create_script "${actions_dir}/44-open-installed-app-sync-report.sh" "exec xdg-open \"${installed_app_sync_report}\""
create_script "${actions_dir}/45-generate-app-collections.sh" "exec /usr/local/bin/lumina-windows-app-collections --profile-id ${profile_id}"
create_script "${actions_dir}/46-open-app-collections-report.sh" "exec xdg-open \"${app_collections_report}\""
create_script "${actions_dir}/47-generate-guest-app-publish-pack.sh" "exec /usr/local/bin/lumina-windows-guest-app-publish-pack --profile-id ${profile_id}"
create_script "${actions_dir}/48-open-guest-app-publish-pack-report.sh" "exec xdg-open \"${guest_app_publish_pack_report}\""
create_script "${actions_dir}/49-run-app-publish-sync.sh" "exec /usr/local/bin/lumina-windows-app-publish-sync --profile-id ${profile_id}"
create_script "${actions_dir}/50-open-app-publish-sync-report.sh" "exec xdg-open \"${app_publish_sync_report}\""
create_script "${actions_dir}/51-export-collection-launchers.sh" "exec /usr/local/bin/lumina-windows-collection-menu-export --profile-id ${profile_id}"
create_script "${actions_dir}/52-open-collection-menu-export-report.sh" "exec xdg-open \"${collection_menu_export_report}\""
create_script "${actions_dir}/53-open-collection-menu-export-folder.sh" "exec xdg-open \"${collection_menu_export_dir}\""
create_script "${actions_dir}/54-generate-app-library.sh" "exec /usr/local/bin/lumina-windows-app-library --profile-id ${profile_id}"
create_script "${actions_dir}/55-open-app-library-report.sh" "exec xdg-open \"${app_library_report}\""
create_script "${actions_dir}/56-export-daily-menu-shortcuts.sh" "exec /usr/local/bin/lumina-windows-daily-menu-export --profile-id ${profile_id}"
create_script "${actions_dir}/57-open-daily-menu-export-report.sh" "exec xdg-open \"${daily_menu_export_report}\""
create_script "${actions_dir}/58-open-daily-menu-folder.sh" "exec xdg-open \"${daily_menu_export_dir}\""
create_script "${actions_dir}/59-export-daily-app-pack.sh" "exec /usr/local/bin/lumina-windows-daily-app-pack --profile-id ${profile_id}"
create_script "${actions_dir}/60-open-daily-app-pack-report.sh" "exec xdg-open \"${daily_app_pack_report}\""
create_script "${actions_dir}/61-open-daily-app-pack-folder.sh" "exec xdg-open \"${daily_app_pack_dir}\""
create_script "${actions_dir}/05-open-workspace-summary.sh" "exec xdg-open \"${summary_path}\""
create_script "${actions_dir}/06-open-daily-launch-recipe.sh" "exec xdg-open \"${daily_recipe_path}\""
create_script "${actions_dir}/07-open-notes-folder.sh" "exec xdg-open \"${notes_dir}\""
create_script "${actions_dir}/08-open-vm-share.sh" "exec xdg-open \"${vm_share_dir}\""
create_script "${actions_dir}/10-mark-linux-first-validated.sh" "exec /usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step linux-first-validated"
create_script "${actions_dir}/11-mark-vm-created.sh" "exec /usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step vm-created"
create_script "${actions_dir}/12-mark-vm-configured.sh" "exec /usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step vm-configured"
create_script "${actions_dir}/13-mark-apps-installed.sh" "exec /usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step apps-installed"
create_script "${actions_dir}/14-mark-checklist-complete.sh" "exec /usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step checklist-complete"

touch "${action_pack_marker}"
/usr/local/bin/ahmados-windows-workflow-state --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

{
    printf '# Lumina Windows Workflow Action Pack\n\n'
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Profile: %s\n' "${profile_name}"
    printf -- '- Profile Id: %s\n' "${profile_id}"
    printf -- '- Actions Directory: %s\n' "${actions_dir}"
    printf -- '- Action Pack Marker: %s\n' "${action_pack_marker}"
    printf '\n## Generated Actions\n'
    printf -- '- Open Workflow Hub: %s\n' "${actions_dir}/01-open-workflow-hub.sh"
    printf -- '- Do Next Action: %s\n' "${actions_dir}/02-do-next-action.sh"
    printf -- '- Generate VM Template: %s\n' "${actions_dir}/03-generate-vm-template.sh"
    printf -- '- Generate VM Creation Starter: %s\n' "${actions_dir}/04-generate-vm-creation-starter.sh"
    printf -- '- Generate VM Post-Create Workflow: %s\n' "${actions_dir}/15-generate-vm-postcreate.sh"
    printf -- '- Open VM Post-Create Plan: %s\n' "${actions_dir}/16-open-vm-postcreate-plan.sh"
    printf -- '- Generate App Install Starter: %s\n' "${actions_dir}/17-generate-app-install-starter.sh"
    printf -- '- Open App Install Plan: %s\n' "${actions_dir}/18-open-app-install-plan.sh"
    printf -- '- Generate Workflow Proof Pass: %s\n' "${actions_dir}/19-generate-workflow-proof-pass.sh"
    printf -- '- Open Workflow Proof Plan: %s\n' "${actions_dir}/20-open-workflow-proof-plan.sh"
    printf -- '- Generate Guest Agent Pack: %s\n' "${actions_dir}/21-generate-guest-agent-pack.sh"
    printf -- '- Warm Start VM: %s\n' "${actions_dir}/22-warm-start-vm.sh"
    printf -- '- Sync Launch Results: %s\n' "${actions_dir}/23-sync-launch-results.sh"
    printf -- '- Open Launch Results Report: %s\n' "${actions_dir}/24-open-launch-results-report.sh"
    printf -- '- Generate Guest Onboarding: %s\n' "${actions_dir}/25-generate-guest-onboarding.sh"
    printf -- '- Mark Guest Agent Installed: %s\n' "${actions_dir}/26-mark-guest-agent-installed.sh"
    printf -- '- Open Guest Onboarding Report: %s\n' "${actions_dir}/27-open-guest-onboarding-report.sh"
    printf -- '- Generate App Registration: %s\n' "${actions_dir}/28-generate-app-registration.sh"
    printf -- '- Open App Registration Report: %s\n' "${actions_dir}/29-open-app-registration-report.sh"
    printf -- '- Generate App Launcher Pack: %s\n' "${actions_dir}/30-generate-app-launcher-pack.sh"
    printf -- '- Open App Launcher Pack Report: %s\n' "${actions_dir}/31-open-app-launcher-pack-report.sh"
    printf -- '- Open App Launchers Folder: %s\n' "${actions_dir}/32-open-app-launchers-folder.sh"
    printf -- '- Generate App Surfaces: %s\n' "${actions_dir}/33-generate-app-surfaces.sh"
    printf -- '- Open App Surfaces Report: %s\n' "${actions_dir}/34-open-app-surfaces-report.sh"
    printf -- '- Pick Registered App: %s\n' "${actions_dir}/35-pick-registered-app.sh"
    printf -- '- Generate Guest App Discovery: %s\n' "${actions_dir}/36-generate-guest-app-discovery.sh"
    printf -- '- Open Guest App Discovery Report: %s\n' "${actions_dir}/37-open-guest-app-discovery-report.sh"
    printf -- '- Hydrate App Manifests: %s\n' "${actions_dir}/38-hydrate-app-manifests.sh"
    printf -- '- Open App Manifest Hydration Report: %s\n' "${actions_dir}/39-open-app-manifest-hydration-report.sh"
    printf -- '- Export App Menu Launchers: %s\n' "${actions_dir}/40-export-app-menu-launchers.sh"
    printf -- '- Open App Menu Export Report: %s\n' "${actions_dir}/41-open-app-menu-export-report.sh"
    printf -- '- Open App Menu Export Folder: %s\n' "${actions_dir}/42-open-app-menu-export-folder.sh"
    printf -- '- Run Installed App Sync: %s\n' "${actions_dir}/43-run-installed-app-sync.sh"
    printf -- '- Open Installed App Sync Report: %s\n' "${actions_dir}/44-open-installed-app-sync-report.sh"
    printf -- '- Generate App Collections: %s\n' "${actions_dir}/45-generate-app-collections.sh"
    printf -- '- Open App Collections Report: %s\n' "${actions_dir}/46-open-app-collections-report.sh"
    printf -- '- Generate Guest App Publish Pack: %s\n' "${actions_dir}/47-generate-guest-app-publish-pack.sh"
    printf -- '- Open Guest App Publish Pack Report: %s\n' "${actions_dir}/48-open-guest-app-publish-pack-report.sh"
    printf -- '- Run App Publish Sync: %s\n' "${actions_dir}/49-run-app-publish-sync.sh"
    printf -- '- Open App Publish Sync Report: %s\n' "${actions_dir}/50-open-app-publish-sync-report.sh"
    printf -- '- Export Collection Launchers: %s\n' "${actions_dir}/51-export-collection-launchers.sh"
    printf -- '- Open Collection Menu Export Report: %s\n' "${actions_dir}/52-open-collection-menu-export-report.sh"
    printf -- '- Open Collection Menu Export Folder: %s\n' "${actions_dir}/53-open-collection-menu-export-folder.sh"
    printf -- '- Generate App Library: %s\n' "${actions_dir}/54-generate-app-library.sh"
    printf -- '- Open App Library Report: %s\n' "${actions_dir}/55-open-app-library-report.sh"
    printf -- '- Export Daily Menu Shortcuts: %s\n' "${actions_dir}/56-export-daily-menu-shortcuts.sh"
    printf -- '- Open Daily Menu Export Report: %s\n' "${actions_dir}/57-open-daily-menu-export-report.sh"
    printf -- '- Open Daily Menu Folder: %s\n' "${actions_dir}/58-open-daily-menu-folder.sh"
    printf -- '- Export Daily App Pack: %s\n' "${actions_dir}/59-export-daily-app-pack.sh"
    printf -- '- Open Daily App Pack Report: %s\n' "${actions_dir}/60-open-daily-app-pack-report.sh"
    printf -- '- Open Daily App Pack Folder: %s\n' "${actions_dir}/61-open-daily-app-pack-folder.sh"
    printf -- '- Open Workspace Summary: %s\n' "${actions_dir}/05-open-workspace-summary.sh"
    printf -- '- Open Daily Launch Recipe: %s\n' "${actions_dir}/06-open-daily-launch-recipe.sh"
    printf -- '- Open Notes Folder: %s\n' "${actions_dir}/07-open-notes-folder.sh"
    printf -- '- Open VM Share: %s\n' "${actions_dir}/08-open-vm-share.sh"
    printf -- '- Mark Linux-First Validated: %s\n' "${actions_dir}/10-mark-linux-first-validated.sh"
    printf -- '- Mark VM Created: %s\n' "${actions_dir}/11-mark-vm-created.sh"
    printf -- '- Mark VM Configured: %s\n' "${actions_dir}/12-mark-vm-configured.sh"
    printf -- '- Mark Apps Installed: %s\n' "${actions_dir}/13-mark-apps-installed.sh"
    printf -- '- Mark Checklist Complete: %s\n' "${actions_dir}/14-mark-checklist-complete.sh"
    printf '\n## Related Reports\n'
    printf -- '- Workflow Recipe Report: %s\n' "${recipe_report}"
    printf -- '- Workflow State Report: %s\n' "${state_report}"
    printf -- '- Workflow Hub Report: %s\n' "${hub_report}"
    printf -- '- VM Template Report: %s\n' "${vm_template_report}"
    printf -- '- VM Creation Starter Report: %s\n' "${vm_creation_report}"
    printf -- '- VM Post-Create Report: %s\n' "${vm_postcreate_report}"
    printf -- '- App Install Starter Report: %s\n' "${app_install_report}"
    printf -- '- Workflow Proof Pass Report: %s\n' "${workflow_proof_report}"
    printf -- '- Launch Results Sync Report: %s\n' "${launch_sync_report}"
    printf -- '- Guest Onboarding Report: %s\n' "${guest_onboarding_report}"
    printf -- '- App Registration Report: %s\n' "${app_registration_report}"
    printf -- '- App Launcher Pack Report: %s\n' "${app_launcher_pack_report}"
    printf -- '- App Surfaces Report: %s\n' "${app_surfaces_report}"
    printf -- '- Guest App Discovery Report: %s\n' "${guest_app_discovery_report}"
    printf -- '- App Manifest Hydration Report: %s\n' "${app_manifest_hydration_report}"
    printf -- '- App Menu Export Report: %s\n' "${menu_export_report}"
    printf -- '- Installed App Sync Report: %s\n' "${installed_app_sync_report}"
    printf -- '- App Collections Report: %s\n' "${app_collections_report}"
    printf -- '- Guest App Publish Pack Report: %s\n' "${guest_app_publish_pack_report}"
    printf -- '- App Publish Sync Report: %s\n' "${app_publish_sync_report}"
    printf -- '- Collection Menu Export Report: %s\n' "${collection_menu_export_report}"
    printf -- '- App Library Report: %s\n' "${app_library_report}"
    printf -- '- Daily Menu Export Report: %s\n' "${daily_menu_export_report}"
    printf -- '- Daily App Pack Report: %s\n' "${daily_app_pack_report}"
} > "${action_pack_report}"

printf '%s\n' '========================================'
printf '%s\n' '   Lumina Windows Workflow Action Pack'
printf '%s\n' '========================================'
printf '\n'
printf 'Profile: %s\n' "${profile_name}"
printf 'Actions directory: %s\n' "${actions_dir}"
printf 'Report: %s\n' "${action_pack_report}"
printf '\n'

if [[ ${open_report} -eq 1 ]] && command -v xdg-open >/dev/null 2>&1; then
    xdg-open "${action_pack_report}" >/dev/null 2>&1 || true
fi
