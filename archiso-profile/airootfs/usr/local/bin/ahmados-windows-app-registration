#!/usr/bin/env bash
set -euo pipefail

selected_profile_id=""
open_report=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile-id)
            selected_profile_id="${2:-}"
            shift 2
            ;;
        --no-open)
            open_report=0
            shift
            ;;
        *)
            printf 'Unknown argument: %s\n' "$1" >&2
            exit 1
            ;;
    esac
done

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/ahmados"
documents_root="${XDG_DOCUMENTS_DIR:-$HOME/Documents}"
mkdir -p "${state_root}"

profiles_path="/usr/share/lumina/windows-apps/profiles.tsv"
catalog_path="/usr/share/lumina/windows-apps/catalog.tsv"
registration_report="${state_root}/windows-app-registration.md"
app_install_report="${state_root}/windows-app-install-starter.md"
state_report="${state_root}/windows-workflow-state.md"
hub_report="${state_root}/windows-workflow-hub.md"

if [[ -z "${selected_profile_id}" ]]; then
    selected_profile_id="adobe-creator"
fi

selected_row="$(awk -F'|' -v target="${selected_profile_id}" 'NF >= 8 && $1 == target {print; exit}' "${profiles_path}" || true)"
if [[ -z "${selected_row}" ]]; then
    printf 'Unknown Windows profile id: %s\n' "${selected_profile_id}" >&2
    exit 1
fi

IFS='|' read -r profile_id profile_name focus app_ids basic_route vm_route studio_route notes <<< "${selected_row}"

/usr/local/bin/ahmados-windows-app-install-starter --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

workspace_root="${documents_root}/Lumina Windows Workflows/${profile_id}"
registry_root="${workspace_root}/app-registry"
manifests_dir="${registry_root}/manifests"
checklists_dir="${workspace_root}/checklists"
notes_dir="${workspace_root}/notes"
workflow_state_root="${workspace_root}/state"
installers_dir="${workspace_root}/installers"
share_dir="${workspace_root}/vm-share"
mkdir -p "${registry_root}" "${manifests_dir}" "${checklists_dir}" "${notes_dir}" "${workflow_state_root}" "${installers_dir}" "${share_dir}"

registration_marker="${workflow_state_root}/app-registration-ready.marker"
registration_plan_path="${workspace_root}/app-registration-plan.md"
registration_env_path="${workspace_root}/app-registration.env"
registration_checklist_path="${checklists_dir}/app-registration-checklist.md"
registration_notes_path="${notes_dir}/app-registration-notes.md"
registry_index_path="${registry_root}/registry-index.tsv"

{
    printf 'LUMINA_WINDOWS_PROFILE_ID=%q\n' "${profile_id}"
    printf 'LUMINA_WINDOWS_PROFILE_NAME=%q\n' "${profile_name}"
    printf 'LUMINA_WINDOWS_REGISTRY_ROOT=%q\n' "${registry_root}"
    printf 'LUMINA_WINDOWS_REGISTRY_INDEX=%q\n' "${registry_index_path}"
    printf 'LUMINA_WINDOWS_INSTALLERS_DIR=%q\n' "${installers_dir}"
    printf 'LUMINA_WINDOWS_SHARE_DIR=%q\n' "${share_dir}"
} > "${registration_env_path}"

{
    printf '# %s App Registration Notes\n\n' "${profile_name}"
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Record actual install locations, launch quirks, login requirements, plugin needs, and preferred launch targets here.\n'
} > "${registration_notes_path}"

{
    printf '# %s App Registration Checklist\n\n' "${profile_name}"
    printf -- '- Confirm the app-install stage is genuinely underway before you trust these manifests.\n'
    printf -- '- For each core app, record the real installed launch target inside its manifest.\n'
    printf -- '- Keep installer names or versions visible if the workflow depends on them.\n'
    printf -- '- Record where save/export output should land on the Lumina side.\n'
    printf -- '- Add every launch quirk or first-login surprise to `%s`.\n' "${registration_notes_path}"
    printf -- '- Use these manifests as the source of truth before the workflow proof pass.\n'
} > "${registration_checklist_path}"

{
    printf '# id|name|category|registration_state|preferred_route|manifest_path\n'
} > "${registry_index_path}"

registration_targets=""

IFS=',' read -r -a app_id_array <<< "${app_ids}"
for app_id in "${app_id_array[@]}"; do
    app_row="$(awk -F'|' -v target="${app_id}" 'NF >= 7 && $1 == target {print; exit}' "${catalog_path}" || true)"
    if [[ -z "${app_row}" ]]; then
        continue
    fi

    IFS='|' read -r catalog_id app_name category basic_path vm_path studio_path catalog_notes <<< "${app_row}"
    manifest_path="${manifests_dir}/${catalog_id}.md"
    preferred_route="${vm_path}"
    registration_state="planned"
    launch_target="<fill after install>"
    export_test_path="<fill after first proof pass>"
    preserved_notes=""

    if [[ -f "${manifest_path}" ]]; then
        existing_registration_state="$(awk -F': ' '/^- Registration State:/ {print $2; exit}' "${manifest_path}" 2>/dev/null || true)"
        existing_launch_target="$(awk -F': ' '/^- Suggested Launch Target:/ {print $2; exit}' "${manifest_path}" 2>/dev/null || true)"
        existing_export_test_path="$(awk -F': ' '/^- Suggested Export\/Test Path:/ {print $2; exit}' "${manifest_path}" 2>/dev/null || true)"
        preserved_notes="$(awk 'found && /^- / {print} /^## Notes$/ {found=1}' "${manifest_path}" 2>/dev/null || true)"

        if [[ -n "${existing_registration_state}" ]]; then
            registration_state="${existing_registration_state}"
        fi

        if [[ -n "${existing_launch_target}" ]]; then
            launch_target="${existing_launch_target}"
        fi

        if [[ -n "${existing_export_test_path}" ]]; then
            export_test_path="${existing_export_test_path}"
        fi
    fi

    {
        printf '# %s Registration Manifest\n\n' "${app_name}"
        printf -- '- App Id: %s\n' "${catalog_id}"
        printf -- '- Profile Id: %s\n' "${profile_id}"
        printf -- '- Category: %s\n' "${category}"
        printf -- '- Registration State: %s\n' "${registration_state}"
        printf -- '- Preferred Route: %s\n' "${preferred_route}"
        printf -- '- Linux-First Hint: %s\n' "${basic_path}"
        printf -- '- Windows Workspace Hint: %s\n' "${vm_path}"
        printf -- '- Studio Hint: %s\n' "${studio_path}"
        printf -- '- Suggested Installer Drop: %s\n' "${installers_dir}"
        printf -- '- Suggested Share Path: %s\n' "${share_dir}"
        printf -- '- Suggested Launch Target: %s\n' "${launch_target}"
        printf -- '- Suggested Export/Test Path: %s\n' "${export_test_path}"
        printf '\n## Notes\n'
        if [[ -n "${preserved_notes}" ]]; then
            printf '%s\n' "${preserved_notes}"
        else
            printf -- '- %s\n' "${catalog_notes}"
            printf -- '- Fill the real launch target after install so Lumina can later move from raw files toward known app entries.\n'
        fi
    } > "${manifest_path}"

    printf '%s|%s|%s|%s|%s|%s\n' \
        "${catalog_id}" "${app_name}" "${category}" "${registration_state}" "${preferred_route}" "${manifest_path}" >> "${registry_index_path}"

    registration_targets+="- ${app_name}: ${manifest_path}\n"
done

if [[ -z "${registration_targets}" ]]; then
    registration_targets="- No concrete app manifests were generated from this profile yet.\n"
fi

{
    printf '# %s App Registration Plan\n\n' "${profile_name}"
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Profile Id: %s\n' "${profile_id}"
    printf -- '- Registry Root: %s\n' "${registry_root}"
    printf '\n## Generated Manifests\n'
    printf '%b' "${registration_targets}"
    printf '\n## What This Stage Does\n'
    printf -- '- turns the workflow from a generic app-install stage into named app manifests\n'
    printf -- '- gives Lumina a concrete place to record real launch targets and install reality\n'
    printf -- '- prepares the proof pass to validate known apps instead of anonymous software steps\n'
    printf '\n## Files For This Stage\n'
    printf -- '- Registration Env: %s\n' "${registration_env_path}"
    printf -- '- Registry Index: %s\n' "${registry_index_path}"
    printf -- '- Registration Checklist: %s\n' "${registration_checklist_path}"
    printf -- '- Registration Notes: %s\n' "${registration_notes_path}"
} > "${registration_plan_path}"

touch "${registration_marker}"
/usr/local/bin/ahmados-windows-workflow-state --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

{
    printf '# Lumina Windows App Registration\n\n'
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Profile: %s\n' "${profile_name}"
    printf -- '- Profile Id: %s\n' "${profile_id}"
    printf -- '- App Registration Plan: %s\n' "${registration_plan_path}"
    printf -- '- App Registration Env: %s\n' "${registration_env_path}"
    printf -- '- Registry Index: %s\n' "${registry_index_path}"
    printf -- '- App Registration Checklist: %s\n' "${registration_checklist_path}"
    printf -- '- App Registration Notes: %s\n' "${registration_notes_path}"
    printf -- '- App Registration Marker: %s\n' "${registration_marker}"
    printf '\n## Related Reports\n'
    printf -- '- App Install Starter Report: %s\n' "${app_install_report}"
    printf -- '- Workflow State Report: %s\n' "${state_report}"
    printf -- '- Workflow Hub Report: %s\n' "${hub_report}"
} > "${registration_report}"

printf '%s\n' '========================================'
printf '%s\n' '     Lumina Windows App Registration'
printf '%s\n' '========================================'
printf '\n'
printf 'Profile: %s\n' "${profile_name}"
printf 'Registry root: %s\n' "${registry_root}"
printf 'Report: %s\n' "${registration_report}"
printf '\n'

if [[ ${open_report} -eq 1 ]] && command -v xdg-open >/dev/null 2>&1; then
    xdg-open "${registration_report}" >/dev/null 2>&1 || true
fi
