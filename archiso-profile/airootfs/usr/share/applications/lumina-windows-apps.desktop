[Desktop Entry]
Type=Application
Version=1.0
Name=Lumina Windows Apps
Comment=Open the lightweight Lumina Windows Apps surface
Exec=/usr/local/bin/lumina-windows-apps
Icon=applications-other
Terminal=false
Categories=Qt;KDE;System;Utility;
StartupNotify=true
Actions=ChooseWorkflow;ChooseAndPinWorkflow;ClearPinnedWorkflow;OpenDailyHome;

[Desktop Action ChooseWorkflow]
Name=Choose Workflow
Exec=/usr/local/bin/lumina-windows-daily-home --choose-workflow --launch

[Desktop Action ChooseAndPinWorkflow]
Name=Choose and Pin Workflow
Exec=/usr/local/bin/lumina-windows-daily-home --choose-workflow --pin-current --launch

[Desktop Action ClearPinnedWorkflow]
Name=Clear Pinned Workflow
Exec=/usr/local/bin/lumina-windows-daily-home --clear-pin

[Desktop Action OpenDailyHome]
Name=Open Daily Home Report
Exec=/usr/local/bin/lumina-windows-daily-home-refresh
