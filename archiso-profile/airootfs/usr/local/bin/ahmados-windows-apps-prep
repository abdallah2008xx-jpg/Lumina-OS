#!/usr/bin/env bash
set -euo pipefail

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/ahmados"
documents_root="${XDG_DOCUMENTS_DIR:-$HOME/Documents}"
mkdir -p "${state_root}"

lock_dir="${state_root}/windows-apps-prep.lock"
if ! mkdir "${lock_dir}" 2>/dev/null; then
    exit 0
fi
trap 'rmdir "${lock_dir}" >/dev/null 2>&1 || true' EXIT

prep_report="${state_root}/windows-apps-ready.md"
compat_report="${state_root}/windows-compat-report.md"
bridge_report="${state_root}/windows-apps-bridge.md"
catalog_report="${state_root}/windows-app-catalog.md"
lab_report="${state_root}/windows-vm-lab.md"
daily_home_state="${state_root}/windows-daily-home.env"
daily_refresh_report="${state_root}/windows-daily-refresh.md"
daily_surface_report="${state_root}/windows-daily-surface.md"
daily_app_pack_report="${state_root}/windows-daily-app-pack.md"
daily_recent_report="${state_root}/windows-daily-recent-sync.md"
daily_quick_launch_report="${state_root}/windows-daily-quick-launch.md"

/usr/local/bin/ahmados-windows-compat-check >/dev/null 2>&1 || true
compatibility_tier="$(awk -F': ' '/^- Compatibility Tier:/ {print $2; exit}' "${compat_report}" 2>/dev/null || true)"
resource_class="$(awk -F': ' '/^- Resource Class:/ {print $2; exit}' "${compat_report}" 2>/dev/null || true)"
if [[ -z "${resource_class}" ]]; then
    resource_class="balanced"
fi

default_daily_profile="adobe-creator"
if [[ "${resource_class}" == "light" ]]; then
    default_daily_profile="office-productivity"
fi

recent_daily_profile="$(awk -F= '/^RECENT_WORKFLOW_ID=/{print $2; exit}' "${daily_home_state}" 2>/dev/null || true)"
recent_daily_mode="$(awk -F= '/^RECENT_WORKFLOW_MODE=/{print $2; exit}' "${daily_home_state}" 2>/dev/null || true)"
recent_daily_outcome="$(awk -F= '/^RECENT_LAUNCH_OUTCOME=/{print $2; exit}' "${daily_home_state}" 2>/dev/null || true)"
pinned_daily_profile="$(awk -F= '/^PINNED_WORKFLOW_ID=/{print $2; exit}' "${daily_home_state}" 2>/dev/null || true)"
preferred_daily_profile="${default_daily_profile}"
recent_daily_reusable="yes"
pinned_daily_reusable="yes"

case "${recent_daily_outcome}" in
    deferred-for-smoothness|queue-sync|awaiting-guest-sync|awaiting-guest|not-run|failed|error)
        recent_daily_reusable="no"
        ;;
esac

if [[ -n "${pinned_daily_profile}" ]]; then
    pinned_row="$(awk -F'|' -v target="${pinned_daily_profile}" 'NF >= 8 && $1 == target {print; exit}' "${profiles_path:-/usr/share/lumina/windows-apps/profiles.tsv}" 2>/dev/null || true)"
    if [[ -n "${pinned_row}" ]]; then
        pinned_state_root="${documents_root}/Lumina Windows Workflows/${pinned_daily_profile}/state"
        if [[ ! -f "${pinned_state_root}/daily-quick-launch-ready.marker" && ! -f "${pinned_state_root}/daily-recent-ready.marker" && ! -f "${pinned_state_root}/app-library-ready.marker" ]]; then
            pinned_daily_reusable="no"
        fi
    else
        pinned_daily_reusable="no"
    fi
fi

if [[ -n "${pinned_daily_profile}" && "${pinned_daily_reusable}" == "yes" ]]; then
    preferred_daily_profile="${pinned_daily_profile}"
elif [[ -n "${recent_daily_profile}" && "${recent_daily_reusable}" == "yes" ]]; then
    recent_row="$(awk -F'|' -v target="${recent_daily_profile}" 'NF >= 8 && $1 == target {print; exit}' "${profiles_path:-/usr/share/lumina/windows-apps/profiles.tsv}" 2>/dev/null || true)"
    if [[ -n "${recent_row}" && ( "${recent_daily_mode}" == "quick-launch" || "${recent_daily_mode}" == "daily-surface" ) ]]; then
        preferred_daily_profile="${recent_daily_profile}"
    fi
fi

daily_profile_state_root="${documents_root}/Lumina Windows Workflows/${preferred_daily_profile}/state"
daily_app_library_marker="${daily_profile_state_root}/app-library-ready.marker"
daily_workflow_proof_marker="${daily_profile_state_root}/workflow-proof-ready.marker"
daily_checklist_complete_marker="${daily_profile_state_root}/checklist-complete.marker"

vm_lab_prep="full"
if [[ "${resource_class}" == "light" ]]; then
    vm_lab_prep="deferred"
fi

daily_runtime_prep="deferred"
if [[ "${resource_class}" != "light" ]]; then
    daily_runtime_prep="warm"
elif [[ -f "${daily_app_library_marker}" && -f "${daily_workflow_proof_marker}" && -f "${daily_checklist_complete_marker}" ]]; then
    daily_runtime_prep="light-mature-only"
fi

if [[ "${vm_lab_prep}" == "full" ]]; then
    /usr/local/bin/ahmados-windows-vm-lab --no-open --no-launch >/dev/null 2>&1 || true
fi
/usr/local/bin/ahmados-windows-apps-catalog --no-open >/dev/null 2>&1 || true
/usr/local/bin/ahmados-windows-apps --no-open >/dev/null 2>&1 || true

if [[ "${daily_runtime_prep}" != "deferred" ]]; then
    /usr/local/bin/ahmados-windows-daily-refresh --profile-id "${preferred_daily_profile}" --no-open >/dev/null 2>&1 || true
    /usr/local/bin/ahmados-windows-daily-recent-sync --profile-id "${preferred_daily_profile}" --no-open >/dev/null 2>&1 || true
    /usr/local/bin/ahmados-windows-daily-quick-launch --profile-id "${preferred_daily_profile}" --no-open >/dev/null 2>&1 || true
fi

experience_mode="$(awk -F': ' '/^- Experience Mode:/ {print $2; exit}' "${bridge_report}" 2>/dev/null || true)"

libvirt_probe="not-attempted"
if [[ "${vm_lab_prep}" == "full" ]] && command -v virsh >/dev/null 2>&1; then
    if virsh -c qemu:///system list --all >/dev/null 2>&1; then
        libvirt_probe="ready"
    else
        libvirt_probe="attention"
    fi
elif [[ "${vm_lab_prep}" == "deferred" ]]; then
    libvirt_probe="deferred-lightweight"
fi

{
    printf '# Lumina Windows Apps Background Prep\n\n'
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Compatibility Tier: %s\n' "${compatibility_tier:-unknown}"
    printf -- '- Resource Class: %s\n' "${resource_class}"
    printf -- '- VM Lab Prep: %s\n' "${vm_lab_prep}"
    printf -- '- Daily Runtime Prep: %s\n' "${daily_runtime_prep}"
    printf -- '- Default Daily Profile: %s\n' "${default_daily_profile}"
    printf -- '- Pinned Daily Profile: %s\n' "${pinned_daily_profile:-none}"
    printf -- '- Pinned Daily Reusable: %s\n' "${pinned_daily_reusable}"
    printf -- '- Recent Daily Profile: %s\n' "${recent_daily_profile:-none}"
    printf -- '- Recent Daily Mode: %s\n' "${recent_daily_mode:-none}"
    printf -- '- Recent Daily Outcome: %s\n' "${recent_daily_outcome:-none}"
    printf -- '- Recent Daily Reusable: %s\n' "${recent_daily_reusable}"
    printf -- '- Daily Profile Warmed: %s\n' "${preferred_daily_profile}"
    printf -- '- Experience Mode: %s\n' "${experience_mode:-unknown}"
    printf -- '- libvirt Probe: %s\n' "${libvirt_probe}"
    printf -- '- Goal: Keep the Windows Apps path warm in the background without opening extra windows.\n'
    printf '\n## Prepared Artifacts\n'
    printf -- '- Compatibility Report: %s\n' "${compat_report}"
    printf -- '- Windows Apps Report: %s\n' "${bridge_report}"
    printf -- '- App Catalog Report: %s\n' "${catalog_report}"
    printf -- '- Advanced Lab Report: %s\n' "${lab_report}"
    printf -- '- Daily Refresh Report: %s\n' "${daily_refresh_report}"
    printf -- '- Daily Surface Report: %s\n' "${daily_surface_report}"
    printf -- '- Daily App Pack Report: %s\n' "${daily_app_pack_report}"
    printf -- '- Daily Recent Sync Report: %s\n' "${daily_recent_report}"
    printf -- '- Daily Quick Launch Report: %s\n' "${daily_quick_launch_report}"
    printf '\n## Behavior\n'
    printf -- '- This prep step does not open a VM or a second desktop by itself.\n'
    printf -- '- It only prepares the Windows Apps path so the visible experience can feel faster and more integrated later.\n'
    if [[ "${vm_lab_prep}" == "deferred" ]]; then
        printf -- '- On light machines, Lumina defers the heavier VM-lab prep so the session stays responsive.\n'
    fi
    if [[ "${daily_runtime_prep}" == "light-mature-only" ]]; then
        printf -- '- On light machines, Lumina only refreshes the daily runtime path when the selected default workflow is already mature enough for real daily use.\n'
    elif [[ "${daily_runtime_prep}" == "deferred" ]]; then
        printf -- '- On this session, Lumina deferred daily runtime warm-up to avoid unnecessary background work.\n'
    fi
} > "${prep_report}"
