#!/usr/bin/env bash
set -euo pipefail

selected_profile_id=""
perform_open=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile-id)
            selected_profile_id="${2:-}"
            shift 2
            ;;
        --no-open)
            perform_open=0
            shift
            ;;
        *)
            printf 'Unknown argument: %s\n' "$1" >&2
            exit 1
            ;;
    esac
done

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/ahmados"
documents_root="${XDG_DOCUMENTS_DIR:-$HOME/Documents}"
mkdir -p "${state_root}"

profiles_path="/usr/share/lumina/windows-apps/profiles.tsv"
next_action_report="${state_root}/windows-workflow-next-action.md"
hub_report="${state_root}/windows-workflow-hub.md"
profile_report="${state_root}/windows-profile-assistant.md"
compat_report="${state_root}/windows-compat-report.md"
vm_warm_start_report="${state_root}/windows-vm-warm-start.md"

if [[ -z "${selected_profile_id}" ]]; then
    selected_profile_id="adobe-creator"
fi

selected_row="$(awk -F'|' -v target="${selected_profile_id}" 'NF >= 8 && $1 == target {print; exit}' "${profiles_path}" || true)"
if [[ -z "${selected_row}" ]]; then
    printf 'Unknown Windows profile id: %s\n' "${selected_profile_id}" >&2
    exit 1
fi

IFS='|' read -r profile_id profile_name focus app_ids basic_route vm_route studio_route notes <<< "${selected_row}"

/usr/local/bin/ahmados-windows-workflow-hub --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

workspace_root="${documents_root}/Lumina Windows Workflows/${profile_id}"
workflow_state_root="${workspace_root}/state"
notes_dir="${workspace_root}/notes"
actions_dir="${workspace_root}/actions"
daily_recipe_path="${workspace_root}/checklists/daily-launch-recipe.md"
checklist_path="${workspace_root}/checklists/first-session-checklist.md"
vm_postcreate_plan_path="${workspace_root}/vm-postcreate-plan.md"
runbook_report="${state_root}/windows-profile-runbook.md"
workflow_state_report="${state_root}/windows-workflow-state.md"
vm_template_report="${state_root}/windows-vm-template.md"
vm_creation_report="${state_root}/windows-vm-creation-starter.md"
vm_postcreate_report="${state_root}/windows-vm-postcreate.md"
app_install_report="${state_root}/windows-app-install-starter.md"
app_registration_report="${state_root}/windows-app-registration.md"
app_launcher_pack_report="${state_root}/windows-app-launcher-pack.md"
app_surfaces_report="${state_root}/windows-app-surfaces.md"
app_menu_export_report="${state_root}/windows-app-menu-export.md"
installed_app_sync_report="${state_root}/windows-installed-app-sync.md"
guest_app_publish_pack_report="${state_root}/windows-guest-app-publish-pack.md"
app_publish_sync_report="${state_root}/windows-app-publish-sync.md"
app_collections_report="${state_root}/windows-app-collections.md"
collection_menu_export_report="${state_root}/windows-collection-menu-export.md"
app_library_report="${state_root}/windows-app-library.md"
daily_menu_export_report="${state_root}/windows-daily-menu-export.md"
daily_app_pack_report="${state_root}/windows-daily-app-pack.md"
daily_app_picker_report="${state_root}/windows-daily-app-picker.md"
daily_runtime_report="${state_root}/windows-daily-runtime.md"
daily_recent_report="${state_root}/windows-daily-recent-sync.md"
daily_quick_launch_report="${state_root}/windows-daily-quick-launch.md"
workflow_proof_report="${state_root}/windows-workflow-proof-pass.md"
guest_agent_pack_report="${state_root}/windows-guest-agent-pack.md"
vm_warm_start_report="${state_root}/windows-vm-warm-start.md"
launch_sync_report="${state_root}/windows-launch-results-sync.md"
guest_onboarding_report="${state_root}/windows-guest-onboarding.md"
guest_app_discovery_report="${state_root}/windows-guest-app-discovery.md"
app_manifest_hydration_report="${state_root}/windows-app-manifest-hydration.md"

bootstrap_marker="${workflow_state_root}/bootstrap-ready.marker"
launch_recipe_marker="${workflow_state_root}/launch-recipe-ready.marker"
action_pack_marker="${workflow_state_root}/action-pack-ready.marker"
vm_template_marker="${workflow_state_root}/vm-template-ready.marker"
vm_creation_marker="${workflow_state_root}/vm-creation-starter-ready.marker"
vm_postcreate_marker="${workflow_state_root}/vm-postcreate-ready.marker"
app_install_marker="${workflow_state_root}/app-install-starter-ready.marker"
app_registration_marker="${workflow_state_root}/app-registration-ready.marker"
app_launcher_pack_marker="${workflow_state_root}/app-launcher-pack-ready.marker"
app_surfaces_marker="${workflow_state_root}/app-surfaces-ready.marker"
app_menu_export_marker="${workflow_state_root}/app-menu-export-ready.marker"
installed_app_sync_marker="${workflow_state_root}/installed-app-sync-ready.marker"
guest_app_publish_pack_marker="${workflow_state_root}/guest-app-publish-pack-ready.marker"
app_publish_sync_marker="${workflow_state_root}/app-publish-sync-ready.marker"
app_collections_marker="${workflow_state_root}/app-collections-ready.marker"
collection_menu_export_marker="${workflow_state_root}/collection-menu-export-ready.marker"
app_library_marker="${workflow_state_root}/app-library-ready.marker"
daily_menu_export_marker="${workflow_state_root}/daily-menu-export-ready.marker"
daily_app_pack_marker="${workflow_state_root}/daily-app-pack-ready.marker"
daily_recent_marker="${workflow_state_root}/daily-recent-ready.marker"
daily_quick_launch_marker="${workflow_state_root}/daily-quick-launch-ready.marker"
workflow_proof_marker="${workflow_state_root}/workflow-proof-ready.marker"
guest_agent_pack_marker="${workflow_state_root}/guest-agent-pack-ready.marker"
launch_result_seen_marker="${workflow_state_root}/launch-result-seen.marker"
launch_request_pending_marker="${workflow_state_root}/launch-request-pending.marker"
launch_queue_pressure_marker="${workflow_state_root}/launch-queue-pressure.marker"
guest_onboarding_marker="${workflow_state_root}/guest-onboarding-ready.marker"
guest_agent_installed_marker="${workflow_state_root}/guest-agent-installed.marker"
guest_app_discovery_marker="${workflow_state_root}/guest-app-discovery-ready.marker"
app_manifest_hydration_marker="${workflow_state_root}/app-manifest-hydration-ready.marker"
vm_created_marker="${workflow_state_root}/vm-created.marker"
vm_configured_marker="${workflow_state_root}/vm-configured.marker"
apps_installed_marker="${workflow_state_root}/apps-installed.marker"
checklist_complete_marker="${workflow_state_root}/checklist-complete.marker"
linux_first_validated_marker="${workflow_state_root}/linux-first-validated.marker"

recommended_route="$(awk -F': ' '/^- Recommended Route:/ {print $2; exit}' "${profile_report}" 2>/dev/null || true)"
resource_class="$(awk -F': ' '/^- Resource Class:/ {print $2; exit}' "${compat_report}" 2>/dev/null || true)"
resource_summary="$(awk -F': ' '/^- Resource Summary:/ {print $2; exit}' "${compat_report}" 2>/dev/null || true)"
warm_start_status="$(awk -F': ' '/^- Warm Start Status:/ {print $2; exit}' "${vm_warm_start_report}" 2>/dev/null || true)"
pressure_state="$(awk -F': ' '/^- Pressure State:/ {print $2; exit}' "${vm_warm_start_report}" 2>/dev/null || true)"
workflow_guard="$(awk -F': ' '/^- Workflow Guard:/ {print $2; exit}' "${vm_warm_start_report}" 2>/dev/null || true)"
launch_queue_health="$(awk -F': ' '/^- Launch Queue Health:/ {print $2; exit}' "${launch_sync_report}" 2>/dev/null || true)"
queue_note="$(awk -F': ' '/^- Queue Note:/ {print $2; exit}' "${launch_sync_report}" 2>/dev/null || true)"
if [[ -z "${recommended_route}" ]]; then
    recommended_route="${basic_route}"
fi
[[ -n "${resource_class}" ]] || resource_class="balanced"
[[ -n "${pressure_state}" ]] || pressure_state="unknown"
[[ -n "${workflow_guard}" ]] || workflow_guard="unknown"
[[ -n "${launch_queue_health}" ]] || launch_queue_health="unknown"
[[ -n "${queue_note}" ]] || queue_note="No queue note captured."

route_mode="linux-first"
if [[ "${recommended_route}" == *"Out of scope"* ]]; then
    route_mode="out-of-scope"
elif [[ "${recommended_route}" == *"GPU focus"* ]]; then
    route_mode="studio-vm"
elif [[ "${recommended_route}" == *"Windows VM"* ]]; then
    route_mode="windows-vm"
fi

action_label="Open workflow hub"
action_kind="report"
action_target="${hub_report}"
action_command="xdg-open \"${hub_report}\""
action_reason="The workflow hub is the safest fallback when no stronger action is needed."

if [[ "${resource_class}" == "light" && "${route_mode}" != "linux-first" && -f "${vm_created_marker}" && "${warm_start_status}" == "already-running" && ! -f "${launch_request_pending_marker}" ]]; then
    action_label="Cool down the idle Windows workspace"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-vm-runner --profile-id ${profile_id} --cooldown"
    action_command="/usr/local/bin/lumina-windows-vm-runner --profile-id ${profile_id} --cooldown"
    action_reason="This Windows workspace is already warm on a light machine and no launch is pending, so reclaiming resources is the smoothest next move."
elif [[ "${resource_class}" == "light" && -f "${launch_queue_pressure_marker}" ]]; then
    action_label="Clear and sync the Windows launch queue"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-launch-results-sync --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-launch-results-sync --profile-id ${profile_id}"
    action_reason="Multiple staged launch requests are piling up on a light machine, so Lumina should sync and shrink the queue before adding more Windows load."
elif [[ "${resource_class}" == "light" && "${route_mode}" == "linux-first" && ! -f "${linux_first_validated_marker}" ]]; then
    action_label="Validate the Linux-first route first"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step linux-first-validated"
    action_command="/usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step linux-first-validated"
    action_reason="This machine is light, so the smoothest next move is to validate the Linux-first path before expanding Windows background load."
elif [[ "${resource_class}" == "light" && "${pressure_state}" == "guarded-lightweight" && "${workflow_guard}" == "single-workflow" ]]; then
    action_label="Review the lightweight app library first"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-app-library --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-app-library --profile-id ${profile_id}"
    action_reason="Lightweight guard is active, so Lumina should review the lighter published app set before scheduling more Windows load."
elif [[ ! -f "${bootstrap_marker}" ]]; then
    action_label="Prepare the Lumina workspace"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-workflow-bootstrap --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-workflow-bootstrap --profile-id ${profile_id}"
    action_reason="The workspace must exist before the rest of the workflow can become repeatable."
elif [[ ! -f "${launch_recipe_marker}" ]]; then
    action_label="Generate the daily launch recipe"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-workflow-recipe --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-workflow-recipe --profile-id ${profile_id}"
    action_reason="The recipe turns setup data into a usable daily routine."
elif [[ ! -f "${action_pack_marker}" ]]; then
    action_label="Generate the workspace action pack"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-workflow-action-pack --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-workflow-action-pack --profile-id ${profile_id}"
    action_reason="The action pack gives the workflow clickable helpers instead of raw commands."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${vm_template_marker}" ]]; then
    action_label="Generate the VM template"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-vm-template --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-vm-template --profile-id ${profile_id}"
    action_reason="The VM shape should be documented clearly before the actual Windows workspace is created."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${vm_creation_marker}" ]]; then
    action_label="Generate the VM creation starter"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-vm-creation-starter --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-vm-creation-starter --profile-id ${profile_id}"
    action_reason="The creation starter translates the VM template into actual files, paths, and a starter command skeleton."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${vm_postcreate_marker}" ]]; then
    action_label="Generate the VM post-create workflow"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-vm-postcreate --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-vm-postcreate --profile-id ${profile_id}"
    action_reason="The post-create workflow prepares the first-boot, drivers, share-validation, and clean-snapshot stage before the VM gets marked as configured."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${guest_agent_pack_marker}" ]]; then
    action_label="Generate the guest agent pack"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-guest-agent-pack --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-guest-agent-pack --profile-id ${profile_id}"
    action_reason="The guest agent pack gives the Windows side a real launch queue contract instead of leaving hidden app launches undefined."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${guest_onboarding_marker}" ]]; then
    action_label="Generate the guest onboarding plan"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-guest-onboarding --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-guest-onboarding --profile-id ${profile_id}"
    action_reason="The guest onboarding layer turns the generated agent files into a concrete Windows-side install path and checklist."
elif [[ "${route_mode}" != "out-of-scope" && -f "${launch_request_pending_marker}" ]]; then
    action_label="Sync launch results"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-launch-results-sync --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-launch-results-sync --profile-id ${profile_id}"
    action_reason="A staged request is still pending. Syncing results tells Lumina whether the Windows guest consumed it yet."
elif [[ "${route_mode}" != "out-of-scope" && -f "${launch_result_seen_marker}" && ! -f "${guest_agent_installed_marker}" ]]; then
    action_label="Mark guest agent installed"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step guest-agent-installed"
    action_command="/usr/local/bin/lumina-windows-workflow-mark --profile-id ${profile_id} --step guest-agent-installed"
    action_reason="Lumina already has launch proof from the guest, so the workflow can now close the guest-agent install gate honestly."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_install_marker}" ]]; then
    action_label="Generate the app install starter"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-app-install-starter --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-app-install-starter --profile-id ${profile_id}"
    action_reason="The app install starter prepares the first core software pass before the workflow gets marked as apps-installed."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_registration_marker}" ]]; then
    action_label="Generate app registration manifests"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-app-registration --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-app-registration --profile-id ${profile_id}"
    action_reason="The app registration layer gives Lumina named manifests for the installed app set before the workflow proof pass."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${guest_app_discovery_marker}" ]]; then
    action_label="Generate the guest app discovery pack"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-guest-app-discovery --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-guest-app-discovery --profile-id ${profile_id}"
    action_reason="This prepares the Windows-side discovery pass that can find real installed app targets for the registered app set."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_manifest_hydration_marker}" ]]; then
    action_label="Hydrate app manifests from guest discovery"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-app-manifest-hydration --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-app-manifest-hydration --profile-id ${profile_id}"
    action_reason="This fills the registered app manifests with real launch targets from the latest Windows-side discovery results."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_launcher_pack_marker}" ]]; then
    action_label="Generate app launcher pack"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-app-launcher-pack --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-app-launcher-pack --profile-id ${profile_id}"
    action_reason="The launcher pack turns registered apps into concrete launch surfaces instead of leaving them as manifests only."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_surfaces_marker}" ]]; then
    action_label="Generate app surfaces"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-app-surfaces --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-app-surfaces --profile-id ${profile_id}"
    action_reason="The app surfaces layer indexes the named Windows launch surfaces so Lumina can present known apps as real launchable entities."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_menu_export_marker}" ]]; then
    action_label="Export registered app launchers into the Lumina menu"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-app-menu-export --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-app-menu-export --profile-id ${profile_id}"
    action_reason="The menu export stage turns known Windows app surfaces into real Lumina menu entries instead of hiding them inside workspace files."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${installed_app_sync_marker}" ]]; then
    action_label="Run installed-app sync and launcher refresh"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-installed-app-sync --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-installed-app-sync --profile-id ${profile_id}"
    action_reason="This refresh stage consolidates launch results, guest discovery, manifest hydration, launcher rebuild, and menu export in one pass."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${guest_app_publish_pack_marker}" ]]; then
    action_label="Generate the guest app publish pack"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-guest-app-publish-pack --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-guest-app-publish-pack --profile-id ${profile_id}"
    action_reason="This prepares the Windows-side publish contract so installed app targets can be published back into Lumina as a stronger inventory source."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_publish_sync_marker}" ]]; then
    action_label="Sync the published app inventory"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-app-publish-sync --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-app-publish-sync --profile-id ${profile_id}"
    action_reason="After the generated publish runner is used inside Windows, this sync absorbs the stronger published inventory so Lumina stops depending only on discovery results."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_collections_marker}" ]]; then
    action_label="Generate app collections"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-app-collections --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-app-collections --profile-id ${profile_id}"
    action_reason="This collection stage groups the Windows app surfaces into Lumina-facing sets instead of leaving everything as individual launchers."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${collection_menu_export_marker}" ]]; then
    action_label="Export collection launchers into the Lumina menu"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-collection-menu-export --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-collection-menu-export --profile-id ${profile_id}"
    action_reason="This export stage makes the Windows app collections visible in the Lumina menu instead of leaving them buried inside workflow files."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${app_library_marker}" ]]; then
    action_label="Generate the Windows app library view"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-app-library --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-app-library --profile-id ${profile_id}"
    action_reason="This builds a single Lumina-facing library view so published apps, discovered apps, and collections feel like one product surface."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${daily_menu_export_marker}" ]]; then
    action_label="Export daily menu shortcuts"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-daily-menu-export --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-daily-menu-export --profile-id ${profile_id}"
    action_reason="This adds lightweight daily shortcuts so the mature Windows path is easier to reach from Lumina without reopening the setup layers."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${daily_app_pack_marker}" ]]; then
    action_label="Export the daily published app pack"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-daily-app-pack --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-daily-app-pack --profile-id ${profile_id}"
    action_reason="This promotes the best published Windows apps into a lighter daily launcher set so the experience feels closer to direct app launching."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${daily_recent_marker}" && -f "${daily_app_pack_marker}" ]]; then
    action_label="Capture the recent daily app fast path"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-daily-recent-sync --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-daily-recent-sync --profile-id ${profile_id}"
    action_reason="This prepares a faster re-entry path so Lumina can reopen the last published daily app instead of re-choosing from scratch."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${daily_quick_launch_marker}" && -f "${daily_app_pack_marker}" ]]; then
    action_label="Generate the daily quick-launch path"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-daily-quick-launch --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-daily-quick-launch --profile-id ${profile_id}"
    action_reason="This captures the smoothest current daily path so Lumina can reopen it with less decision overhead."
elif [[ "${route_mode}" != "out-of-scope" && -f "${app_library_marker}" && -f "${daily_app_pack_marker}" && -f "${workflow_proof_marker}" && -f "${checklist_complete_marker}" && "${resource_class}" == "light" && -f "${daily_recent_marker}" ]]; then
    action_label="Run the daily quick-launch path"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-daily-quick-launch --profile-id ${profile_id} --launch"
    action_command="/usr/local/bin/lumina-windows-daily-quick-launch --profile-id ${profile_id} --launch"
    action_reason="This workflow is already proven, so Lumina can now reopen the quickest honest daily path instead of re-entering the chooser flow."
elif [[ "${route_mode}" != "out-of-scope" && -f "${app_library_marker}" && -f "${daily_app_pack_marker}" && -f "${workflow_proof_marker}" && -f "${checklist_complete_marker}" && "${resource_class}" == "light" ]]; then
    action_label="Run the daily quick-launch path"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-daily-quick-launch --profile-id ${profile_id} --launch"
    action_command="/usr/local/bin/lumina-windows-daily-quick-launch --profile-id ${profile_id} --launch"
    action_reason="This workflow is already proven, so Lumina can now reopen the smoothest daily path directly instead of making the user decide between app and collection paths."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${workflow_proof_marker}" ]]; then
    action_label="Generate the workflow proof pass"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-workflow-proof-pass --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-workflow-proof-pass --profile-id ${profile_id}"
    action_reason="The proof pass should exist before Lumina treats the named registered-app launch path as a real workflow validation step."
elif [[ "${route_mode}" == "out-of-scope" ]]; then
    action_label="Open workflow notes"
    action_kind="path"
    action_target="${notes_dir}"
    action_command="xdg-open \"${notes_dir}\""
    action_reason="Unsupported workflows should move through clear notes, not hidden promises."
elif [[ "${route_mode}" == "linux-first" && ! -f "${linux_first_validated_marker}" ]]; then
    action_label="Open the daily launch recipe"
    action_kind="path"
    action_target="${daily_recipe_path}"
    action_command="xdg-open \"${daily_recipe_path}\""
    action_reason="Linux-first workflows should start from the documented rhythm before any marker is closed."
elif [[ "${route_mode}" != "linux-first" && ! -f "${vm_created_marker}" ]]; then
    action_label="Create the Windows workspace VM"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-vm-launcher --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-vm-launcher --profile-id ${profile_id}"
    action_reason="The VM launcher creates the VM and opens virt-manager in one step."
elif [[ "${route_mode}" != "linux-first" && ! -f "${vm_configured_marker}" ]]; then
    action_label="Configure the Windows VM"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-auto-configure --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-auto-configure --profile-id ${profile_id}"
    action_reason="The auto-configure tool checks networking, shares, and snapshots for you."
elif [[ "${route_mode}" != "linux-first" && ! -f "${apps_installed_marker}" ]]; then
    action_label="Open the app install plan"
    action_kind="path"
    action_target="${app_install_report}"
    action_command="xdg-open \"${app_install_report}\""
    action_reason="The first core software pass should follow the app install plan instead of going straight into ad-hoc installs."
elif [[ "${route_mode}" != "out-of-scope" && -f "${app_library_marker}" && -f "${workflow_proof_marker}" && -f "${checklist_complete_marker}" ]]; then
    action_label="Launch the best published Windows app collection"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-app-library --profile-id ${profile_id} --launch-best"
    action_command="/usr/local/bin/lumina-windows-app-library --profile-id ${profile_id} --launch-best"
    action_reason="This workflow is already proven and checklist-complete, so Lumina can treat the app library as a daily-use launch surface instead of a setup report."
elif [[ "${route_mode}" != "out-of-scope" && ! -f "${checklist_complete_marker}" ]]; then
    action_label="Pick a registered app and dry-run the named launch path"
    action_kind="command"
    action_target="/usr/local/bin/lumina-windows-registered-app-picker --profile-id ${profile_id}"
    action_command="/usr/local/bin/lumina-windows-registered-app-picker --profile-id ${profile_id}"
    action_reason="Before closing the workflow proof gate, Lumina should prove it can pick and stage a named Windows app instead of only handling raw files."
fi

{
    printf '# Lumina Windows Workflow Next Action\n\n'
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Profile: %s\n' "${profile_name}"
    printf -- '- Profile Id: %s\n' "${profile_id}"
    printf -- '- Recommended Route: %s\n' "${recommended_route}"
    printf -- '- Resource Class: %s\n' "${resource_class}"
    printf -- '- Resource Summary: %s\n' "${resource_summary:-unknown}"
    printf -- '- Warm Start Status: %s\n' "${warm_start_status:-not-run}"
    printf -- '- Pressure State: %s\n' "${pressure_state}"
    printf -- '- Workflow Guard: %s\n' "${workflow_guard}"
    printf -- '- Launch Queue Health: %s\n' "${launch_queue_health}"
    printf '\n## Selected Action\n'
    printf -- '- Label: %s\n' "${action_label}"
    printf -- '- Kind: %s\n' "${action_kind}"
    printf -- '- Target: %s\n' "${action_target}"
    printf -- '- Reason: %s\n' "${action_reason}"
    printf -- '- Queue Note: %s\n' "${queue_note}"
    printf '\n## Reference Reports\n'
    printf -- '- Workflow Hub Report: %s\n' "${hub_report}"
    printf -- '- Workflow State Report: %s\n' "${workflow_state_report}"
    printf -- '- Workflow Runbook Report: %s\n' "${runbook_report}"
    printf -- '- VM Template Report: %s\n' "${vm_template_report}"
    printf -- '- VM Creation Starter Report: %s\n' "${vm_creation_report}"
    printf -- '- VM Post-Create Report: %s\n' "${vm_postcreate_report}"
    printf -- '- App Install Starter Report: %s\n' "${app_install_report}"
    printf -- '- App Registration Report: %s\n' "${app_registration_report}"
    printf -- '- App Launcher Pack Report: %s\n' "${app_launcher_pack_report}"
    printf -- '- App Surfaces Report: %s\n' "${app_surfaces_report}"
    printf -- '- App Menu Export Report: %s\n' "${app_menu_export_report}"
    printf -- '- Installed App Sync Report: %s\n' "${installed_app_sync_report}"
    printf -- '- Guest App Publish Pack Report: %s\n' "${guest_app_publish_pack_report}"
    printf -- '- App Publish Sync Report: %s\n' "${app_publish_sync_report}"
    printf -- '- App Collections Report: %s\n' "${app_collections_report}"
    printf -- '- Collection Menu Export Report: %s\n' "${collection_menu_export_report}"
    printf -- '- App Library Report: %s\n' "${app_library_report}"
    printf -- '- Daily Menu Export Report: %s\n' "${daily_menu_export_report}"
    printf -- '- Daily App Pack Report: %s\n' "${daily_app_pack_report}"
    printf -- '- Daily App Picker Report: %s\n' "${daily_app_picker_report}"
    printf -- '- Daily Runtime Report: %s\n' "${daily_runtime_report}"
    printf -- '- Daily Recent Sync Report: %s\n' "${daily_recent_report}"
    printf -- '- Daily Quick Launch Report: %s\n' "${daily_quick_launch_report}"
    printf -- '- Workflow Proof Pass Report: %s\n' "${workflow_proof_report}"
    printf -- '- Guest Agent Pack Report: %s\n' "${guest_agent_pack_report}"
    printf -- '- VM Warm Start Report: %s\n' "${vm_warm_start_report}"
    printf -- '- Launch Results Sync Report: %s\n' "${launch_sync_report}"
    printf -- '- Guest Onboarding Report: %s\n' "${guest_onboarding_report}"
    printf -- '- Guest App Discovery Report: %s\n' "${guest_app_discovery_report}"
    printf -- '- App Manifest Hydration Report: %s\n' "${app_manifest_hydration_report}"
} > "${next_action_report}"

if [[ ${perform_open} -eq 1 ]]; then
    case "${action_kind}" in
        command)
            eval "${action_command}" >/dev/null 2>&1 || true
            ;;
        path|report)
            if command -v xdg-open >/dev/null 2>&1; then
                xdg-open "${action_target}" >/dev/null 2>&1 || true
            fi
            ;;
    esac
fi

printf '%s\n' '========================================'
printf '%s\n' '    Lumina Windows Workflow Next Action'
printf '%s\n' '========================================'
printf '\n'
printf 'Profile: %s\n' "${profile_name}"
printf 'Action: %s\n' "${action_label}"
printf 'Report: %s\n' "${next_action_report}"
printf '\n'
