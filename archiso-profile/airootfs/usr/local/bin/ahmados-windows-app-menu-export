#!/usr/bin/env bash
set -euo pipefail

selected_profile_id=""
open_report=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile-id)
            selected_profile_id="${2:-}"
            shift 2
            ;;
        --no-open)
            open_report=0
            shift
            ;;
        *)
            printf 'Unknown argument: %s\n' "$1" >&2
            exit 1
            ;;
    esac
done

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/ahmados"
documents_root="${XDG_DOCUMENTS_DIR:-$HOME/Documents}"
data_root="${XDG_DATA_HOME:-$HOME/.local/share}"
mkdir -p "${state_root}"

profiles_path="/usr/share/lumina/windows-apps/profiles.tsv"
menu_export_report="${state_root}/windows-app-menu-export.md"
launcher_pack_report="${state_root}/windows-app-launcher-pack.md"
app_surfaces_report="${state_root}/windows-app-surfaces.md"
state_report="${state_root}/windows-workflow-state.md"
hub_report="${state_root}/windows-workflow-hub.md"

if [[ -z "${selected_profile_id}" ]]; then
    selected_profile_id="adobe-creator"
fi

selected_row="$(awk -F'|' -v target="${selected_profile_id}" 'NF >= 8 && $1 == target {print; exit}' "${profiles_path}" || true)"
if [[ -z "${selected_row}" ]]; then
    printf 'Unknown Windows profile id: %s\n' "${selected_profile_id}" >&2
    exit 1
fi

IFS='|' read -r profile_id profile_name focus app_ids basic_route vm_route studio_route notes <<< "${selected_row}"

/usr/local/bin/ahmados-windows-app-launcher-pack --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true
/usr/local/bin/ahmados-windows-app-surfaces --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

workspace_root="${documents_root}/Lumina Windows Workflows/${profile_id}"
registry_root="${workspace_root}/app-registry"
registry_index_path="${registry_root}/registry-index.tsv"
launchers_dir="${registry_root}/launchers"
workflow_state_root="${workspace_root}/state"
export_dir="${data_root}/applications/lumina-windows-apps/${profile_id}"
menu_export_marker="${workflow_state_root}/app-menu-export-ready.marker"

mkdir -p "${export_dir}" "${workflow_state_root}"

export_count=0
export_lines=""

while IFS='|' read -r app_id app_name app_category registration_state preferred_route manifest_path; do
    [[ "${app_id}" == \#* || -z "${app_id}" ]] && continue

    exported_path="${export_dir}/lumina-windows-${profile_id}-${app_id}.desktop"

    cat > "${exported_path}" <<EOF
[Desktop Entry]
Type=Application
Version=1.0
Name=${app_name} (Lumina Windows)
Comment=Launch ${app_name} through Lumina Windows Apps
Exec=/usr/local/bin/lumina-windows-registered-app-launch --profile-id ${profile_id} --app-id ${app_id}
Icon=application-x-ms-dos-executable
Terminal=false
Categories=Utility;System;
StartupNotify=true
Keywords=Windows;Lumina;${app_name};
EOF

    export_count=$((export_count + 1))
    export_lines+="- ${app_name}: ${exported_path}\n"
done < "${registry_index_path}"

if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database "${export_dir}" >/dev/null 2>&1 || true
fi

if [[ -z "${export_lines}" ]]; then
    export_lines="- No menu launchers were exported because the registry index is empty.\n"
fi

touch "${menu_export_marker}"
/usr/local/bin/ahmados-windows-workflow-state --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

{
    printf '# Lumina Windows App Menu Export\n\n'
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Profile: %s\n' "${profile_name}"
    printf -- '- Profile Id: %s\n' "${profile_id}"
    printf -- '- Export Directory: %s\n' "${export_dir}"
    printf -- '- Exported Launchers: %s\n' "${export_count}"
    printf -- '- App Menu Export Marker: %s\n' "${menu_export_marker}"
    printf -- '- Workspace Launchers Directory: %s\n' "${launchers_dir}"
    printf '\n## Exported Launchers\n'
    printf '%b' "${export_lines}"
    printf '\n## Related Reports\n'
    printf -- '- App Launcher Pack Report: %s\n' "${launcher_pack_report}"
    printf -- '- App Surfaces Report: %s\n' "${app_surfaces_report}"
    printf -- '- Workflow State Report: %s\n' "${state_report}"
    printf -- '- Workflow Hub Report: %s\n' "${hub_report}"
} > "${menu_export_report}"

printf '%s\n' '========================================'
printf '%s\n' '    Lumina Windows App Menu Export'
printf '%s\n' '========================================'
printf '\n'
printf 'Profile: %s\n' "${profile_name}"
printf 'Exported launchers: %s\n' "${export_count}"
printf 'Export dir: %s\n' "${export_dir}"
printf 'Report: %s\n' "${menu_export_report}"
printf '\n'

if [[ ${open_report} -eq 1 ]] && command -v xdg-open >/dev/null 2>&1; then
    xdg-open "${menu_export_report}" >/dev/null 2>&1 || true
fi
