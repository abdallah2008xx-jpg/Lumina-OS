#!/usr/bin/env bash
set -euo pipefail

stamp_dir="${HOME}/.config/ahmados"
stamp_file="${stamp_dir}/session-defaults-applied"
config_file="${stamp_dir}/welcome.conf"

force_apply=0

if [[ "${1:-}" == "--force" ]]; then
    force_apply=1
fi

mkdir -p "${stamp_dir}"

if [[ "${force_apply}" -ne 1 && -f "${stamp_file}" ]]; then
    exit 0
fi

read_config_value() {
    local key="$1"
    local default_value="$2"
    local value=""

    if [[ -f "${config_file}" ]]; then
        value="$(awk -F= -v target="${key}" '
            BEGIN {
                in_general = 0
            }
            /^\[/ {
                in_general = ($0 == "[General]")
                next
            }
            in_general && $1 == target {
                print substr($0, index($0, "=") + 1)
                exit
            }
        ' "${config_file}")"
    fi

    if [[ -n "${value}" ]]; then
        printf '%s\n' "${value}"
    else
        printf '%s\n' "${default_value}"
    fi
}

resolve_lookandfeel() {
    case "$1" in
        classic)
            printf '%s\n' "com.ahmados.desktop.classic"
            ;;
        minimal)
            printf '%s\n' "com.ahmados.desktop.minimal"
            ;;
        *)
            printf '%s\n' "com.ahmados.desktop"
            ;;
    esac
}

resolve_colorscheme() {
    case "$1" in
        dark)
            printf '%s\n' "AhmadOSNight"
            ;;
        *)
            printf '%s\n' "AhmadOS"
            ;;
    esac
}

layout_choice="$(read_config_value "layout" "balanced")"
appearance_choice="$(read_config_value "appearance" "light")"
wallpaper_choice="$(read_config_value "wallpaper" "/usr/share/ahmados/wallpapers/ahmados-lagoon.svg")"
lookandfeel_package="$(resolve_lookandfeel "${layout_choice}")"
colorscheme_name="$(resolve_colorscheme "${appearance_choice}")"

sleep 4

if command -v plasma-apply-lookandfeel >/dev/null 2>&1; then
    plasma-apply-lookandfeel -a "${lookandfeel_package}" || true
elif command -v lookandfeeltool >/dev/null 2>&1; then
    lookandfeeltool -a "${lookandfeel_package}" || true
fi

if command -v plasma-apply-colorscheme >/dev/null 2>&1; then
    plasma-apply-colorscheme "${colorscheme_name}" || true
fi

if command -v plasma-apply-wallpaperimage >/dev/null 2>&1; then
    plasma-apply-wallpaperimage "${wallpaper_choice}" || true
fi

if command -v kwriteconfig6 >/dev/null 2>&1; then
    kwriteconfig6 --file kdeglobals --group KDE --key LookAndFeelPackage "${lookandfeel_package}" || true
    kwriteconfig6 --file kdeglobals --group General --key ColorScheme "${colorscheme_name}" || true
    kwriteconfig6 --file kdeglobals --group General --key Name "AhmadOS" || true
fi

touch "${stamp_file}"
