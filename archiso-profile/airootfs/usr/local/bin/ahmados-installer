#!/usr/bin/env bash
set -euo pipefail

terminal_bin="$(command -v konsole || true)"
run_script="$(mktemp /tmp/lumina-installer.XXXXXX.sh)"

cat > "${run_script}" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

wait_for_enter() {
    printf '\n'
    read -r -p "Press Enter to close this window..." _
}

clear
printf '%s\n' '========================================'
printf '%s\n' '        Install Lumina-OS'
printf '%s\n' '========================================'
printf '\n'
printf '%s\n' 'This starts the guided Arch installer (archinstall).'
printf '%s\n' 'Recommended before you continue:'
printf '%s\n' '  - confirm your target disk is selected correctly'
printf '%s\n' '  - keep a backup of any important data'
printf '%s\n' '  - stay connected to power on laptops'
printf '\n'
printf '%s\n' 'Installer logs will be written under /var/log/archinstall.'
printf '%s\n' 'Close this terminal only after the installer finishes.'
printf '\n'
printf '%s\n' 'Important: when archinstall completes, choose "Exit archinstall".'
printf '%s\n' 'Lumina-OS will then finalize the installed system automatically.'
printf '%s\n' 'If you reboot directly from archinstall, boot the live ISO again and run "Finalize Installed Lumina-OS".'
printf '\n'

if command -v nm-online >/dev/null 2>&1; then
    printf '%s\n' 'Checking network readiness...'
    if ! nm-online -q --timeout=20; then
        printf '\n'
        printf '%s\n' 'Network is not ready yet.'
        printf '%s\n' 'Connect the VM or device to the internet, then retry the installer.'
        printf '%s\n' 'You can confirm connectivity from a terminal with: ping -c 1 archlinux.org'
        wait_for_enter
        exit 1
    fi
    printf '%s\n' 'Network looks ready.'
    printf '\n'
fi

printf '%s\n' 'Checking pacman keyring readiness...'
if ! sudo pacman-key --list-keys >/tmp/lumina-installer-keyring-check.log 2>&1; then
    printf '%s\n' 'Pacman keyring is not ready yet. Initializing it now...'
    if ! sudo pacman-key --init >/tmp/lumina-installer-keyring-init.log 2>&1; then
        printf '\n'
        printf '%s\n' 'Failed to initialize the pacman keyring.'
        printf '%s\n' 'Inspect: /tmp/lumina-installer-keyring-init.log'
        printf '\n'
        tail -n 20 /tmp/lumina-installer-keyring-init.log || true
        wait_for_enter
        exit 1
    fi

    if ! sudo pacman-key --populate archlinux >/tmp/lumina-installer-keyring-populate.log 2>&1; then
        printf '\n'
        printf '%s\n' 'Failed to populate the Arch Linux pacman keyring.'
        printf '%s\n' 'Inspect: /tmp/lumina-installer-keyring-populate.log'
        printf '\n'
        tail -n 20 /tmp/lumina-installer-keyring-populate.log || true
        wait_for_enter
        exit 1
    fi
fi

printf '%s\n' 'Pacman keyring looks ready.'
printf '\n'

printf '%s\n' 'Refreshing the Arch package database before opening the installer...'
if ! sudo pacman -Sy --noconfirm > /tmp/lumina-installer-pacman.log 2>&1; then
    printf '\n'
    printf '%s\n' 'Failed to sync the Arch Linux package database.'
    printf '%s\n' 'This usually means the live session has no internet access yet or the mirror request failed.'
    printf '%s\n' 'Try again after network access is working, or inspect: /tmp/lumina-installer-pacman.log'
    printf '\n'
    tail -n 20 /tmp/lumina-installer-pacman.log || true
    wait_for_enter
    exit 1
fi

printf '%s\n' 'Package database refreshed successfully.'
printf '\n'

archinstall_status=0
if ! sudo archinstall; then
    archinstall_status=$?
fi

finalize_target=""
for candidate in /mnt /mnt/archinstall; do
    if [[ -f "${candidate}/etc/os-release" ]]; then
        finalize_target="${candidate}"
        break
    fi
done

if [[ "${archinstall_status}" -eq 0 && -n "${finalize_target}" ]]; then
    printf '\n'
    printf '%s\n' 'Finalizing the installed Lumina-OS system...'
    if ! sudo /usr/local/bin/lumina-finalize-install > /tmp/lumina-installer-finalize.log 2>&1; then
        printf '\n'
        printf '%s\n' 'Lumina-OS could not finish the post-install finalize step automatically.'
        printf '%s\n' 'Inspect: /tmp/lumina-installer-finalize.log'
        printf '%s\n' 'From the live session, run "Finalize Installed Lumina-OS" and retry the reboot.'
        printf '\n'
        tail -n 40 /tmp/lumina-installer-finalize.log || true
        wait_for_enter
        exit 1
    fi

    printf '\n'
    printf '%s\n' 'Lumina-OS finalize completed.'
    printf '%s\n' 'You can now reboot into the installed system.'
    wait_for_enter
    exit 0
fi

if [[ -n "${finalize_target}" ]]; then
    printf '\n'
    printf '%s\n' 'An installed target was detected, but the automatic Lumina finalize step did not run.'
    printf '%s\n' 'From the live session, run "Finalize Installed Lumina-OS" and then reboot.'
    wait_for_enter
fi

exit "${archinstall_status}"
EOF

chmod 755 "${run_script}"

if [[ -n "${terminal_bin}" ]]; then
    exec "${terminal_bin}" --hold -p tabtitle="Install Lumina-OS" -e "${run_script}"
fi

exec "${run_script}"
