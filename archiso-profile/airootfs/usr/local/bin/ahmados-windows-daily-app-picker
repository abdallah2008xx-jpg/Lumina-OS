#!/usr/bin/env bash
set -euo pipefail

selected_profile_id=""
launch_best=0
choose_app=0
open_report=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile-id)
            selected_profile_id="${2:-}"
            shift 2
            ;;
        --launch-best)
            launch_best=1
            shift
            ;;
        --choose-app)
            choose_app=1
            shift
            ;;
        --no-open)
            open_report=0
            shift
            ;;
        *)
            printf 'Unknown argument: %s\n' "$1" >&2
            exit 1
            ;;
    esac
done

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/ahmados"
documents_root="${XDG_DOCUMENTS_DIR:-$HOME/Documents}"
mkdir -p "${state_root}"

profiles_path="/usr/share/lumina/windows-apps/profiles.tsv"
picker_report="${state_root}/windows-daily-app-picker.md"
daily_app_pack_report="${state_root}/windows-daily-app-pack.md"
launch_report="${state_root}/windows-registered-app-launch.md"
state_report="${state_root}/windows-workflow-state.md"
hub_report="${state_root}/windows-workflow-hub.md"

if [[ -z "${selected_profile_id}" ]]; then
    selected_profile_id="adobe-creator"
fi

selected_row="$(awk -F'|' -v target="${selected_profile_id}" 'NF >= 8 && $1 == target {print; exit}' "${profiles_path}" || true)"
if [[ -z "${selected_row}" ]]; then
    printf 'Unknown Windows profile id: %s\n' "${selected_profile_id}" >&2
    exit 1
fi

IFS='|' read -r profile_id profile_name focus app_ids basic_route vm_route studio_route notes <<< "${selected_row}"

/usr/local/bin/ahmados-windows-daily-app-pack --profile-id "${profile_id}" --no-open >/dev/null 2>&1 || true

workspace_root="${documents_root}/Lumina Windows Workflows/${profile_id}"
registry_root="${workspace_root}/app-registry"
registry_index_path="${registry_root}/registry-index.tsv"
workflow_state_root="${workspace_root}/state"
daily_app_pack_marker="${workflow_state_root}/daily-app-pack-ready.marker"

data_root="${XDG_DATA_HOME:-$HOME/.local/share}"
export_dir="${data_root}/applications/lumina-windows-daily-apps/${profile_id}"

selected_app_id=""
selected_app_name=""
selected_app_category=""

candidate_inventory_path="$(mktemp)"
trap 'rm -f "${candidate_inventory_path}"' EXIT

for desktop_path in "${export_dir}"/lumina-windows-daily-app-"${profile_id}"-*.desktop; do
    [[ -f "${desktop_path}" ]] || continue
    app_id="$(basename "${desktop_path}" .desktop)"
    app_id="${app_id#lumina-windows-daily-app-${profile_id}-}"
    registry_row="$(awk -F'|' -v target="${app_id}" 'NF >= 6 && $1 == target {print; exit}' "${registry_index_path}" 2>/dev/null || true)"
    [[ -n "${registry_row}" ]] || continue
    IFS='|' read -r row_app_id row_app_name row_app_category row_registration_state row_preferred_route row_manifest_path <<< "${registry_row}"
    printf '%s|%s|%s|%s\n' "${row_app_id}" "${row_app_name}" "${row_app_category}" "${desktop_path}" >> "${candidate_inventory_path}"
done

choose_app_with_kdialog() {
    local entries=()
    while IFS='|' read -r app_id app_name app_category desktop_path; do
        [[ -z "${app_id}" ]] && continue
        entries+=("${app_id}" "${app_name} - ${app_category}")
    done < "${candidate_inventory_path}"

    if [[ ${#entries[@]} -eq 0 ]]; then
        return 1
    fi

    kdialog --title "Lumina Windows Apps" \
        --menu "Choose the daily Windows app Lumina should launch." \
        "${entries[@]}" 2>/dev/null || return 1
}

if [[ ${choose_app} -eq 1 && -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]] && command -v kdialog >/dev/null 2>&1; then
    selected_app_id="$(choose_app_with_kdialog || true)"
fi

if [[ -z "${selected_app_id}" ]]; then
    selected_app_id="$(awk -F'|' 'NF >= 4 {print $1; exit}' "${candidate_inventory_path}" 2>/dev/null || true)"
fi

if [[ -n "${selected_app_id}" ]]; then
    selected_row="$(awk -F'|' -v target="${selected_app_id}" 'NF >= 4 && $1 == target {print; exit}' "${candidate_inventory_path}" || true)"
    IFS='|' read -r selected_app_id selected_app_name selected_app_category selected_desktop_path <<< "${selected_row}"
fi

launch_outcome="no-daily-app-ready"
launch_note="No published-ready daily app shortcut exists yet for this workflow."
guest_launch_status="not-run"
picker_mode="report-only"

if [[ -n "${selected_app_id}" ]]; then
    if [[ ${choose_app} -eq 1 ]]; then
        picker_mode="choose-app"
    else
        picker_mode="launch-best"
    fi

    /usr/local/bin/ahmados-windows-registered-app-launch --profile-id "${profile_id}" --app-id "${selected_app_id}" --no-open >/dev/null 2>&1 || true
    launch_outcome="$(awk -F': ' '/^- Launch Outcome:/ {print $2; exit}' "${launch_report}" 2>/dev/null || true)"
    guest_launch_status="$(awk -F': ' '/^- Guest Launch Status:/ {print $2; exit}' "${launch_report}" 2>/dev/null || true)"
    launch_note="$(awk 'found && /^- / {sub(/^- /,""); print; exit} /^## Launch Note/ {found=1}' "${launch_report}" 2>/dev/null || true)"
    [[ -n "${launch_outcome}" ]] || launch_outcome="unknown"
    [[ -n "${guest_launch_status}" ]] || guest_launch_status="unknown"
    [[ -n "${launch_note}" ]] || launch_note="No launch note was captured."
fi

{
    printf '# Lumina Windows Daily App Picker\n\n'
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Profile: %s\n' "${profile_name}"
    printf -- '- Profile Id: %s\n' "${profile_id}"
    printf -- '- Picker Mode: %s\n' "${picker_mode}"
    printf -- '- Daily App Pack Marker: %s\n' "${daily_app_pack_marker}"
    printf -- '- Selected App Id: %s\n' "${selected_app_id:-none}"
    printf -- '- Selected App Name: %s\n' "${selected_app_name:-none}"
    printf -- '- Selected Category: %s\n' "${selected_app_category:-none}"
    printf -- '- Launch Outcome: %s\n' "${launch_outcome}"
    printf -- '- Guest Launch Status: %s\n' "${guest_launch_status}"
    printf '\n## Launch Note\n'
    printf -- '- %s\n' "${launch_note}"
    printf '\n## Related Reports\n'
    printf -- '- Daily App Pack Report: %s\n' "${daily_app_pack_report}"
    printf -- '- Registered App Launch Report: %s\n' "${launch_report}"
    printf -- '- Workflow State Report: %s\n' "${state_report}"
    printf -- '- Workflow Hub Report: %s\n' "${hub_report}"
} > "${picker_report}"

printf '%s\n' '========================================'
printf '%s\n' '    Lumina Windows Daily App Picker'
printf '%s\n' '========================================'
printf '\n'
printf 'Profile: %s\n' "${profile_name}"
printf 'Selected app: %s\n' "${selected_app_name:-none}"
printf 'Outcome: %s\n' "${launch_outcome}"
printf 'Report: %s\n' "${picker_report}"
printf '\n'

if [[ ${open_report} -eq 1 ]] && command -v xdg-open >/dev/null 2>&1; then
    xdg-open "${picker_report}" >/dev/null 2>&1 || true
fi
