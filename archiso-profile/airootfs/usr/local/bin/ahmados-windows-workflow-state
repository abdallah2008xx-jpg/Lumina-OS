#!/usr/bin/env bash
set -euo pipefail

selected_profile_id=""
open_report=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile-id)
            selected_profile_id="${2:-}"
            shift 2
            ;;
        --no-open)
            open_report=0
            shift
            ;;
        *)
            printf 'Unknown argument: %s\n' "$1" >&2
            exit 1
            ;;
    esac
done

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/ahmados"
documents_root="${XDG_DOCUMENTS_DIR:-$HOME/Documents}"
mkdir -p "${state_root}"

profiles_path="/usr/share/lumina/windows-apps/profiles.tsv"
state_report="${state_root}/windows-workflow-state.md"
profile_report="${state_root}/windows-profile-assistant.md"
bootstrap_report="${state_root}/windows-workflow-bootstrap.md"
runbook_report="${state_root}/windows-profile-runbook.md"
recipe_report="${state_root}/windows-workflow-recipe.md"
hub_report="${state_root}/windows-workflow-hub.md"
action_pack_report="${state_root}/windows-workflow-action-pack.md"
vm_template_report="${state_root}/windows-vm-template.md"
vm_creation_report="${state_root}/windows-vm-creation-starter.md"
vm_postcreate_report="${state_root}/windows-vm-postcreate.md"
app_install_report="${state_root}/windows-app-install-starter.md"
app_registration_report="${state_root}/windows-app-registration.md"
app_launcher_pack_report="${state_root}/windows-app-launcher-pack.md"
app_surfaces_report="${state_root}/windows-app-surfaces.md"
app_menu_export_report="${state_root}/windows-app-menu-export.md"
installed_app_sync_report="${state_root}/windows-installed-app-sync.md"
guest_app_publish_pack_report="${state_root}/windows-guest-app-publish-pack.md"
app_publish_sync_report="${state_root}/windows-app-publish-sync.md"
app_collections_report="${state_root}/windows-app-collections.md"
collection_menu_export_report="${state_root}/windows-collection-menu-export.md"
app_library_report="${state_root}/windows-app-library.md"
workflow_proof_report="${state_root}/windows-workflow-proof-pass.md"
launch_sync_report="${state_root}/windows-launch-results-sync.md"
guest_onboarding_report="${state_root}/windows-guest-onboarding.md"
guest_app_discovery_report="${state_root}/windows-guest-app-discovery.md"
app_manifest_hydration_report="${state_root}/windows-app-manifest-hydration.md"

if [[ -z "${selected_profile_id}" ]]; then
    selected_profile_id="adobe-creator"
fi

selected_row="$(awk -F'|' -v target="${selected_profile_id}" 'NF >= 8 && $1 == target {print; exit}' "${profiles_path}" || true)"
if [[ -z "${selected_row}" ]]; then
    printf 'Unknown Windows profile id: %s\n' "${selected_profile_id}" >&2
    exit 1
fi

IFS='|' read -r profile_id profile_name focus app_ids basic_route vm_route studio_route notes <<< "${selected_row}"
workspace_root="${documents_root}/Lumina Windows Workflows/${profile_id}"
workflow_state_root="${workspace_root}/state"

mkdir -p "${workflow_state_root}"
bootstrap_marker="${workflow_state_root}/bootstrap-ready.marker"
vm_created_marker="${workflow_state_root}/vm-created.marker"
vm_configured_marker="${workflow_state_root}/vm-configured.marker"
apps_installed_marker="${workflow_state_root}/apps-installed.marker"
checklist_complete_marker="${workflow_state_root}/checklist-complete.marker"
linux_first_validated_marker="${workflow_state_root}/linux-first-validated.marker"
launch_recipe_marker="${workflow_state_root}/launch-recipe-ready.marker"
action_pack_marker="${workflow_state_root}/action-pack-ready.marker"
vm_template_marker="${workflow_state_root}/vm-template-ready.marker"
vm_creation_marker="${workflow_state_root}/vm-creation-starter-ready.marker"
vm_postcreate_marker="${workflow_state_root}/vm-postcreate-ready.marker"
app_install_marker="${workflow_state_root}/app-install-starter-ready.marker"
app_registration_marker="${workflow_state_root}/app-registration-ready.marker"
app_launcher_pack_marker="${workflow_state_root}/app-launcher-pack-ready.marker"
app_surfaces_marker="${workflow_state_root}/app-surfaces-ready.marker"
app_menu_export_marker="${workflow_state_root}/app-menu-export-ready.marker"
installed_app_sync_marker="${workflow_state_root}/installed-app-sync-ready.marker"
guest_app_publish_pack_marker="${workflow_state_root}/guest-app-publish-pack-ready.marker"
app_publish_sync_marker="${workflow_state_root}/app-publish-sync-ready.marker"
app_collections_marker="${workflow_state_root}/app-collections-ready.marker"
collection_menu_export_marker="${workflow_state_root}/collection-menu-export-ready.marker"
app_library_marker="${workflow_state_root}/app-library-ready.marker"
workflow_proof_marker="${workflow_state_root}/workflow-proof-ready.marker"
guest_agent_pack_marker="${workflow_state_root}/guest-agent-pack-ready.marker"
launch_result_seen_marker="${workflow_state_root}/launch-result-seen.marker"
launch_request_pending_marker="${workflow_state_root}/launch-request-pending.marker"
launch_queue_pressure_marker="${workflow_state_root}/launch-queue-pressure.marker"
launch_queue_cleanup_marker="${workflow_state_root}/launch-queue-cleanup.marker"
guest_onboarding_marker="${workflow_state_root}/guest-onboarding-ready.marker"
guest_agent_installed_marker="${workflow_state_root}/guest-agent-installed.marker"
guest_app_discovery_marker="${workflow_state_root}/guest-app-discovery-ready.marker"
app_manifest_hydration_marker="${workflow_state_root}/app-manifest-hydration-ready.marker"
notes_path="${workflow_state_root}/current-notes.md"

touch "${notes_path}"

recommended_route="$(awk -F': ' '/^- Recommended Route:/ {print $2; exit}' "${profile_report}" 2>/dev/null || true)"
if [[ -z "${recommended_route}" ]]; then
    recommended_route="${basic_route}"
fi

launch_queue_health="$(awk -F': ' '/^- Launch Queue Health:/ {print $2; exit}' "${launch_sync_report}" 2>/dev/null || true)"
stale_requests_moved="$(awk -F': ' '/^- Stale Pending Requests Moved:/ {print $2; exit}' "${launch_sync_report}" 2>/dev/null || true)"
old_shared_results_pruned="$(awk -F': ' '/^- Old Shared Results Pruned:/ {print $2; exit}' "${launch_sync_report}" 2>/dev/null || true)"
old_imported_results_archived="$(awk -F': ' '/^- Old Imported Results Archived:/ {print $2; exit}' "${launch_sync_report}" 2>/dev/null || true)"
old_imported_archives_pruned="$(awk -F': ' '/^- Old Imported Archives Pruned:/ {print $2; exit}' "${launch_sync_report}" 2>/dev/null || true)"
queue_note="$(awk -F': ' '/^- Queue Note:/ {print $2; exit}' "${launch_sync_report}" 2>/dev/null || true)"
[[ -n "${launch_queue_health}" ]] || launch_queue_health="unknown"
[[ -n "${stale_requests_moved}" ]] || stale_requests_moved="0"
[[ -n "${old_shared_results_pruned}" ]] || old_shared_results_pruned="0"
[[ -n "${old_imported_results_archived}" ]] || old_imported_results_archived="0"
[[ -n "${old_imported_archives_pruned}" ]] || old_imported_archives_pruned="0"
[[ -n "${queue_note}" ]] || queue_note="No queue note captured."

phase="bootstrap-pending"
status="needs-bootstrap"

if [[ -f "${bootstrap_marker}" ]]; then
    phase="workspace-prepared"
    status="in-progress"
fi

if [[ -f "${launch_recipe_marker}" ]]; then
    phase="launch-recipe-ready"
    status="in-progress"
fi

if [[ -f "${action_pack_marker}" ]]; then
    phase="action-pack-ready"
    status="in-progress"
fi

if [[ -f "${vm_template_marker}" ]]; then
    phase="vm-template-ready"
    status="in-progress"
fi

if [[ -f "${vm_creation_marker}" ]]; then
    phase="vm-creation-ready"
    status="in-progress"
fi

if [[ -f "${vm_postcreate_marker}" ]]; then
    phase="vm-postcreate-ready"
    status="in-progress"
fi

if [[ -f "${guest_agent_pack_marker}" ]]; then
    phase="guest-agent-pack-ready"
    status="in-progress"
fi

if [[ -f "${guest_onboarding_marker}" ]]; then
    phase="guest-onboarding-ready"
    status="in-progress"
fi

if [[ -f "${launch_result_seen_marker}" ]]; then
    phase="launch-result-seen"
    status="in-progress"
fi

if [[ -f "${guest_agent_installed_marker}" ]]; then
    phase="guest-agent-installed"
    status="in-progress"
fi

if [[ -f "${app_install_marker}" ]]; then
    phase="app-install-ready"
    status="in-progress"
fi

if [[ -f "${app_registration_marker}" ]]; then
    phase="app-registration-ready"
    status="in-progress"
fi

if [[ -f "${guest_app_discovery_marker}" ]]; then
    phase="guest-app-discovery-ready"
    status="in-progress"
fi

if [[ -f "${app_manifest_hydration_marker}" ]]; then
    phase="app-manifest-hydration-ready"
    status="in-progress"
fi

if [[ -f "${app_launcher_pack_marker}" ]]; then
    phase="app-launcher-pack-ready"
    status="in-progress"
fi

if [[ -f "${app_surfaces_marker}" ]]; then
    phase="app-surfaces-ready"
    status="in-progress"
fi

if [[ -f "${app_menu_export_marker}" ]]; then
    phase="app-menu-export-ready"
    status="in-progress"
fi

if [[ -f "${installed_app_sync_marker}" ]]; then
    phase="installed-app-sync-ready"
    status="in-progress"
fi

if [[ -f "${guest_app_publish_pack_marker}" ]]; then
    phase="guest-app-publish-pack-ready"
    status="in-progress"
fi

if [[ -f "${app_publish_sync_marker}" ]]; then
    phase="app-publish-sync-ready"
    status="in-progress"
fi

if [[ -f "${app_collections_marker}" ]]; then
    phase="app-collections-ready"
    status="in-progress"
fi

if [[ -f "${collection_menu_export_marker}" ]]; then
    phase="collection-menu-export-ready"
    status="in-progress"
fi

if [[ -f "${app_library_marker}" ]]; then
    phase="app-library-ready"
    status="in-progress"
fi

if [[ -f "${linux_first_validated_marker}" ]]; then
    phase="linux-first-validated"
    status="ready-for-review"
fi

if [[ -f "${vm_created_marker}" ]]; then
    phase="vm-created"
    status="in-progress"
fi

if [[ -f "${vm_configured_marker}" ]]; then
    phase="vm-configured"
    status="in-progress"
fi

if [[ -f "${apps_installed_marker}" ]]; then
    phase="apps-installed"
    status="in-progress"
fi

if [[ -f "${apps_installed_marker}" && -f "${workflow_proof_marker}" ]]; then
    phase="workflow-proof-ready"
    status="in-progress"
fi

if [[ -f "${checklist_complete_marker}" ]]; then
    phase="workflow-ready"
    status="ready-for-next-stage"
fi

{
    printf '# Lumina Windows Workflow State\n\n'
    printf -- '- Generated At: %s\n' "$(date -Is)"
    printf -- '- Profile: %s\n' "${profile_name}"
    printf -- '- Profile Id: %s\n' "${profile_id}"
    printf -- '- Workspace Root: %s\n' "${workspace_root}"
    printf -- '- Recommended Route: %s\n' "${recommended_route:-unknown}"
    printf -- '- Current Phase: %s\n' "${phase}"
    printf -- '- Status: %s\n' "${status}"
    printf '\n## Markers\n'
    printf -- '- Bootstrap Ready: %s\n' "$([[ -f "${bootstrap_marker}" ]] && printf yes || printf no)"
    printf -- '- Launch Recipe Ready: %s\n' "$([[ -f "${launch_recipe_marker}" ]] && printf yes || printf no)"
    printf -- '- Action Pack Ready: %s\n' "$([[ -f "${action_pack_marker}" ]] && printf yes || printf no)"
    printf -- '- VM Template Ready: %s\n' "$([[ -f "${vm_template_marker}" ]] && printf yes || printf no)"
    printf -- '- VM Creation Starter Ready: %s\n' "$([[ -f "${vm_creation_marker}" ]] && printf yes || printf no)"
    printf -- '- VM Post-Create Ready: %s\n' "$([[ -f "${vm_postcreate_marker}" ]] && printf yes || printf no)"
    printf -- '- App Install Starter Ready: %s\n' "$([[ -f "${app_install_marker}" ]] && printf yes || printf no)"
    printf -- '- App Registration Ready: %s\n' "$([[ -f "${app_registration_marker}" ]] && printf yes || printf no)"
    printf -- '- App Launcher Pack Ready: %s\n' "$([[ -f "${app_launcher_pack_marker}" ]] && printf yes || printf no)"
    printf -- '- App Surfaces Ready: %s\n' "$([[ -f "${app_surfaces_marker}" ]] && printf yes || printf no)"
    printf -- '- App Menu Export Ready: %s\n' "$([[ -f "${app_menu_export_marker}" ]] && printf yes || printf no)"
    printf -- '- Installed App Sync Ready: %s\n' "$([[ -f "${installed_app_sync_marker}" ]] && printf yes || printf no)"
    printf -- '- Guest App Publish Pack Ready: %s\n' "$([[ -f "${guest_app_publish_pack_marker}" ]] && printf yes || printf no)"
    printf -- '- App Publish Sync Ready: %s\n' "$([[ -f "${app_publish_sync_marker}" ]] && printf yes || printf no)"
    printf -- '- App Collections Ready: %s\n' "$([[ -f "${app_collections_marker}" ]] && printf yes || printf no)"
    printf -- '- Collection Menu Export Ready: %s\n' "$([[ -f "${collection_menu_export_marker}" ]] && printf yes || printf no)"
    printf -- '- App Library Ready: %s\n' "$([[ -f "${app_library_marker}" ]] && printf yes || printf no)"
    printf -- '- Workflow Proof Ready: %s\n' "$([[ -f "${workflow_proof_marker}" ]] && printf yes || printf no)"
    printf -- '- Guest Agent Pack Ready: %s\n' "$([[ -f "${guest_agent_pack_marker}" ]] && printf yes || printf no)"
    printf -- '- Guest Onboarding Ready: %s\n' "$([[ -f "${guest_onboarding_marker}" ]] && printf yes || printf no)"
    printf -- '- Guest Agent Installed: %s\n' "$([[ -f "${guest_agent_installed_marker}" ]] && printf yes || printf no)"
    printf -- '- Guest App Discovery Ready: %s\n' "$([[ -f "${guest_app_discovery_marker}" ]] && printf yes || printf no)"
    printf -- '- App Manifest Hydration Ready: %s\n' "$([[ -f "${app_manifest_hydration_marker}" ]] && printf yes || printf no)"
    printf -- '- Launch Result Seen: %s\n' "$([[ -f "${launch_result_seen_marker}" ]] && printf yes || printf no)"
    printf -- '- Launch Request Pending: %s\n' "$([[ -f "${launch_request_pending_marker}" ]] && printf yes || printf no)"
    printf -- '- Launch Queue Pressure: %s\n' "$([[ -f "${launch_queue_pressure_marker}" ]] && printf yes || printf no)"
    printf -- '- Launch Queue Cleanup: %s\n' "$([[ -f "${launch_queue_cleanup_marker}" ]] && printf yes || printf no)"
    printf -- '- VM Created: %s\n' "$([[ -f "${vm_created_marker}" ]] && printf yes || printf no)"
    printf -- '- VM Configured: %s\n' "$([[ -f "${vm_configured_marker}" ]] && printf yes || printf no)"
    printf -- '- Apps Installed: %s\n' "$([[ -f "${apps_installed_marker}" ]] && printf yes || printf no)"
    printf -- '- Checklist Complete: %s\n' "$([[ -f "${checklist_complete_marker}" ]] && printf yes || printf no)"
    printf -- '- Linux-First Validated: %s\n' "$([[ -f "${linux_first_validated_marker}" ]] && printf yes || printf no)"
    printf '\n## Launch Queue\n'
    printf -- '- Launch Queue Health: %s\n' "${launch_queue_health}"
    printf -- '- Queue Note: %s\n' "${queue_note}"
    printf -- '- Stale Pending Requests Moved: %s\n' "${stale_requests_moved}"
    printf -- '- Old Shared Results Pruned: %s\n' "${old_shared_results_pruned}"
    printf -- '- Old Imported Results Archived: %s\n' "${old_imported_results_archived}"
    printf -- '- Old Imported Archives Pruned: %s\n' "${old_imported_archives_pruned}"
    printf '\n## State Paths\n'
    printf -- '- Workflow State Root: %s\n' "${workflow_state_root}"
    printf -- '- Notes File: %s\n' "${notes_path}"
    printf '\n## Related Reports\n'
    printf -- '- Profile Assistant Report: %s\n' "${profile_report}"
    printf -- '- Workflow Runbook Report: %s\n' "${runbook_report}"
    printf -- '- Workflow Bootstrap Report: %s\n' "${bootstrap_report}"
    printf -- '- Workflow Recipe Report: %s\n' "${recipe_report}"
    printf -- '- Workflow Action Pack Report: %s\n' "${action_pack_report}"
    printf -- '- VM Template Report: %s\n' "${vm_template_report}"
    printf -- '- VM Creation Starter Report: %s\n' "${vm_creation_report}"
    printf -- '- VM Post-Create Report: %s\n' "${vm_postcreate_report}"
    printf -- '- App Install Starter Report: %s\n' "${app_install_report}"
    printf -- '- App Registration Report: %s\n' "${app_registration_report}"
    printf -- '- App Launcher Pack Report: %s\n' "${app_launcher_pack_report}"
    printf -- '- App Surfaces Report: %s\n' "${app_surfaces_report}"
    printf -- '- App Menu Export Report: %s\n' "${app_menu_export_report}"
    printf -- '- Installed App Sync Report: %s\n' "${installed_app_sync_report}"
    printf -- '- Guest App Publish Pack Report: %s\n' "${guest_app_publish_pack_report}"
    printf -- '- App Publish Sync Report: %s\n' "${app_publish_sync_report}"
    printf -- '- App Collections Report: %s\n' "${app_collections_report}"
    printf -- '- Collection Menu Export Report: %s\n' "${collection_menu_export_report}"
    printf -- '- App Library Report: %s\n' "${app_library_report}"
    printf -- '- Workflow Proof Pass Report: %s\n' "${workflow_proof_report}"
    printf -- '- Launch Results Sync Report: %s\n' "${launch_sync_report}"
    printf -- '- Guest Onboarding Report: %s\n' "${guest_onboarding_report}"
    printf -- '- Guest App Discovery Report: %s\n' "${guest_app_discovery_report}"
    printf -- '- App Manifest Hydration Report: %s\n' "${app_manifest_hydration_report}"
    printf -- '- Workflow Hub Report: %s\n' "${hub_report}"
    printf -- '- Workflow State Report: %s\n' "${state_report}"
} > "${state_report}"

printf '%s\n' '========================================'
printf '%s\n' '     Lumina Windows Workflow State'
printf '%s\n' '========================================'
printf '\n'
printf 'Profile: %s\n' "${profile_name}"
printf 'Phase: %s\n' "${phase}"
printf 'Status: %s\n' "${status}"
printf 'Report: %s\n' "${state_report}"
printf '\n'

if [[ ${open_report} -eq 1 ]] && command -v xdg-open >/dev/null 2>&1; then
    xdg-open "${state_report}" >/dev/null 2>&1 || true
fi
